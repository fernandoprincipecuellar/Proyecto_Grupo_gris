<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoRuta</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-0 py-2" style="background-color: #1b5e20;">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-bold text-white" asp-area="" asp-controller="Home" asp-action="Index">Gris Reciclaje</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item"><a class="nav-link text-white fw-bold" asp-controller="Home" asp-action="Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold" href="#">Asistente</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold" href="#">Escanear</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold" href="#">Premios</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold" asp-controller="Home" asp-action="Profile">Perfil</a></li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-3"><a class="btn btn-outline-light btn-sm px-3" style="border-radius: 6px; font-weight: 300;" href="#">Soporte</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold" asp-controller="Account" asp-action="Register">Register</a></li>
                        <li class="nav-item"><a class="nav-link text-white fw-bold" asp-controller="Account" asp-action="Login">Login</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main role="main">
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>