@using Microsoft.AspNetCore.Identity
@using Proyecto_Grupo_gris.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="relative group">
        <button class="nav-user-btn flex items-center gap-2 px-3 py-1.5 rounded-xl bg-white/10 hover:bg-white/20 border border-white/10 hover:border-white/20 transition-all duration-300">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-secondary-container to-secondary flex items-center justify-center text-white font-bold text-xs shadow-md">
                @User.Identity?.Name?.Substring(0, 1).ToUpper()
            </div>
            <span class="hidden sm:block text-inverse-primary/80 font-label-md text-[13px] max-w-[100px] truncate">@User.Identity?.Name</span>
            <span class="material-symbols-outlined text-inverse-primary/50 text-lg group-hover:rotate-180 transition-transform duration-300">expand_more</span>
        </button>
        <!-- Dropdown -->
        <div class="absolute right-0 top-full mt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50">
            <div class="bg-primary-container/95 backdrop-blur-2xl rounded-2xl border border-white/10 shadow-2xl shadow-black/20 overflow-hidden p-1.5">
                <div class="px-3 py-2.5 border-b border-white/10 mb-1">
                    <p class="text-inverse-primary/90 font-label-md text-[13px] font-semibold truncate">@User.Identity?.Name</p>
                    <p class="text-inverse-primary/40 font-body-md text-xs truncate">@User.FindFirst("Email")?.Value</p>
                </div>
                <a asp-controller="Home" asp-action="Profile" class="flex items-center gap-2.5 px-3 py-2 rounded-xl text-inverse-primary/60 hover:text-white hover:bg-white/5 transition-all duration-200 font-body-md text-sm">
                    <span class="material-symbols-outlined text-lg">person</span> Mi Perfil
                </a>
                <a asp-controller="Home" asp-action="Premios" class="flex items-center gap-2.5 px-3 py-2 rounded-xl text-inverse-primary/60 hover:text-white hover:bg-white/5 transition-all duration-200 font-body-md text-sm">
                    <span class="material-symbols-outlined text-lg">emoji_events</span> Mis Premios
                </a>
                <div class="border-t border-white/10 mt-1 pt-1">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="w-full">
                        <button type="submit" class="flex items-center gap-2.5 px-3 py-2 rounded-xl text-error/70 hover:text-error hover:bg-error/5 transition-all duration-200 font-body-md text-sm w-full">
                            <span class="material-symbols-outlined text-lg">logout</span> Cerrar Sesion
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="flex items-center gap-2">
        <a asp-controller="Account" asp-action="Login" class="px-4 py-2 font-label-md text-[13px] text-inverse-primary/70 hover:text-white rounded-lg hover:bg-white/5 transition-all duration-300">
            Iniciar sesion
        </a>
        <a asp-controller="Account" asp-action="Register" class="nav-cta-btn relative px-5 py-2 rounded-xl bg-secondary-container text-primary font-label-md text-[13px] font-bold overflow-hidden transition-all duration-300 hover:shadow-lg hover:shadow-secondary-container/30 hover:scale-[1.02] active:scale-[0.98]">
            <span class="relative z-10">Registrarse</span>
            <div class="absolute inset-0 bg-gradient-to-r from-secondary-container via-white/20 to-secondary-container opacity-0 hover:opacity-100 transition-opacity duration-300"></div>
        </a>
    </div>
}