@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="py-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto text-center">
    <div class="glass-card rounded-3xl p-10 md:p-16 inline-block max-w-lg">
        <span class="material-symbols-outlined text-error text-6xl mb-4 block">error</span>
        <h1 class="font-display-lg text-headline-lg text-on-surface mb-2">Error</h1>
        <p class="text-on-surface-variant font-body-lg text-body-lg">Ha ocurrido un error al procesar tu solicitud.</p>

        @if (Model.ShowRequestId)
        {
            <div class="mt-6 p-4 rounded-xl bg-surface-container-low inline-block">
                <span class="font-label-md text-label-md text-outline">Request ID:</span>
                <code class="text-secondary font-bold ml-2">@Model.RequestId</code>
            </div>
        }
    </div>
</div>
