@{
    ViewData["Title"] = "Premios y Puntos";
    Layout = "_Layout";
}

<!-- Hero Section -->
<div class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary-container to-tertiary-container"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, rgba(0,250,190,0.4) 1px, transparent 0); background-size: 30px 30px;"></div>
    <div class="absolute top-0 right-1/4 w-72 h-72 bg-secondary/15 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-0 left-1/3 w-64 h-64 bg-secondary-container/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>

    <div class="relative z-10 py-16 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto text-center">
        <span class="material-symbols-outlined text-secondary-container text-5xl mb-4 block animate-float" style="font-variation-settings: 'FILL' 1;">emoji_events</span>
        <h1 class="font-display-lg text-headline-lg-mobile md:text-display-lg text-white mb-3 animate-fade-in-up">Centro de Recompensas</h1>
        <p class="text-inverse-primary/60 font-body-lg text-body-lg max-w-xl mx-auto animate-fade-in-up" style="animation-delay: 0.1s;">Canjea tus EcoPuntos por beneficios exclusivos y sostenibles.</p>
    </div>
</div>

<div class="py-10 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        <!-- Left Column: Stats & Ranking -->
        <aside class="lg:col-span-4 space-y-6">
            <!-- Points Card -->
            <div class="relative p-8 rounded-3xl overflow-hidden animate-fade-in-up" style="background: linear-gradient(135deg, #006c50, #00513c, #001915);">
                <div class="absolute inset-0 opacity-15" style="background-image: radial-gradient(circle at 1px 1px, rgba(0,250,190,0.4) 1px, transparent 0); background-size: 24px 24px;"></div>
                <div class="absolute top-0 right-0 w-40 h-40 bg-secondary-container/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
                <div class="absolute bottom-0 left-0 w-32 h-32 bg-white/5 rounded-full blur-2xl translate-y-1/3 -translate-x-1/4"></div>
                <div class="relative z-10 text-center">
                    <span class="text-secondary-container/60 font-label-md text-[11px] uppercase tracking-[0.2em] block mb-3">Tus EcoPuntos</span>
                    <div class="flex items-center justify-center gap-3 mb-4">
                        <span class="material-symbols-outlined text-secondary-container text-4xl animate-float" style="font-variation-settings: 'FILL' 1;">eco</span>
                        <h2 id="puntos-display" class="font-display-lg text-5xl text-white font-bold animate-fade-in-up" style="animation-delay: 0.2s;">@ViewBag.Puntos</h2>
                    </div>
                    <div class="w-full bg-white/10 h-2.5 rounded-full mb-4 overflow-hidden">
                        <div id="puntos-bar" class="h-full rounded-full animate-glow-pulse" style="width: 65%; background: linear-gradient(90deg, #00fabe, #36ffc4);"></div>
                    </div>
                    <p class="text-inverse-primary/50 font-body-md text-sm">Sigue reciclando para subir de nivel!</p>
                </div>
            </div>

            <!-- Ranking Card -->
            <div class="glass-card rounded-3xl p-6 animate-fade-in-up" style="animation-delay: 0.15s;">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="font-headline-md text-headline-md text-primary flex items-center gap-2">
                        <span class="material-symbols-outlined text-secondary text-xl" style="font-variation-settings: 'FILL' 1;">leaderboard</span>
                        Top Recicladores
                    </h3>
                </div>
                <div class="space-y-3">
                    <div class="flex items-center gap-4 p-3.5 rounded-2xl transition-all duration-300" style="background: linear-gradient(135deg, rgba(0,250,190,0.08), rgba(0,108,80,0.05)); border: 1px solid rgba(0,250,190,0.15);">
                        <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-lg shadow-amber-500/20">
                            <span class="text-white font-bold text-xs">1</span>
                        </div>
                        <div class="w-10 h-10 rounded-2xl bg-secondary/10 flex items-center justify-center">
                            <span class="material-symbols-outlined text-secondary text-lg">person</span>
                        </div>
                        <div class="flex-1">
                            <p class="font-label-md text-label-md text-on-surface font-bold">Maria Gomez</p>
                            <p class="text-[11px] text-on-surface-variant">5,200 pts</p>
                        </div>
                        <span class="material-symbols-outlined text-amber-500 text-xl" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
                    </div>
                    <div class="flex items-center gap-4 p-3.5 rounded-2xl hover:bg-secondary/5 transition-all duration-300 border border-transparent hover:border-outline-variant/30">
                        <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-gray-300 to-gray-500 flex items-center justify-center">
                            <span class="text-white font-bold text-xs">2</span>
                        </div>
                        <div class="w-10 h-10 rounded-2xl bg-surface-container-high flex items-center justify-center">
                            <span class="material-symbols-outlined text-on-surface-variant text-lg">person</span>
                        </div>
                        <div class="flex-1">
                            <p class="font-label-md text-label-md text-on-surface">Carlos Ruiz</p>
                            <p class="text-[11px] text-on-surface-variant">4,850 pts</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 p-3.5 rounded-2xl hover:bg-secondary/5 transition-all duration-300 border border-transparent hover:border-outline-variant/30">
                        <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-amber-600 to-amber-800 flex items-center justify-center">
                            <span class="text-white font-bold text-xs">3</span>
                        </div>
                        <div class="w-10 h-10 rounded-2xl bg-surface-container-high flex items-center justify-center">
                            <span class="material-symbols-outlined text-on-surface-variant text-lg">person</span>
                        </div>
                        <div class="flex-1">
                            <p class="font-label-md text-label-md text-on-surface">Ana Lopez</p>
                            <p class="text-[11px] text-on-surface-variant">4,100 pts</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 p-3.5 rounded-2xl border border-secondary/20" style="background: linear-gradient(135deg, rgba(0,108,80,0.06), rgba(0,250,190,0.04));">
                        <div class="w-8 h-8 rounded-xl bg-secondary flex items-center justify-center shadow-lg shadow-secondary/20">
                            <span class="text-white font-bold text-xs">12</span>
                        </div>
                        <div class="w-10 h-10 rounded-2xl bg-secondary flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-sm">person</span>
                        </div>
                        <div class="flex-1">
                            <p class="font-label-md text-label-md text-secondary font-bold">@ViewBag.UserName (Tu)</p>
                            <p id="user-rank-points" class="text-[11px] text-secondary">@ViewBag.Puntos pts</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Column: Rewards Grid -->
        <section class="lg:col-span-8">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                <div>
                    <h1 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary mb-1">Catalogo de Recompensas</h1>
                    <p class="font-body-md text-body-md text-on-surface-variant">Beneficios exclusivos para eco-ciudadanos activos.</p>
                </div>
            </div>

            <div id="prizes-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="col-span-full text-center py-10">
                    <div class="loading-spinner mx-auto mb-3"></div>
                    <p class="text-on-surface-variant text-sm">Cargando recompensas...</p>
                </div>
            </div>
        </section>
    </div>
</div>

<!-- Toast notification -->
<div id="toast-container" class="fixed bottom-6 right-6 z-50 hidden">
    <div id="toast" class="px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-3 transition-all duration-300 transform translate-y-full opacity-0">
        <span id="toast-icon" class="material-symbols-outlined text-xl"></span>
        <span id="toast-message" class="font-label-md text-sm"></span>
    </div>
</div>

<script>
(function() {
    let userPuntos = @ViewBag.Puntos;

    async function loadPrizes() {
        try {
            const resp = await fetch('/api/v1/prizes');
            if (!resp.ok) throw new Error('Error al cargar premios');
            const prizes = await resp.json();
            renderPrizes(prizes);
        } catch (e) {
            document.getElementById('prizes-grid').innerHTML =
                '<div class="col-span-full text-center py-10"><p class="text-error">Error al cargar recompensas.</p></div>';
        }
    }

    function renderPrizes(prizes) {
        const grid = document.getElementById('prizes-grid');
        if (!prizes.length) {
            grid.innerHTML = '<div class="col-span-full text-center py-10"><p class="text-on-surface-variant">No hay recompensas disponibles.</p></div>';
            return;
        }

        grid.innerHTML = prizes.map((p, i) => {
            const canAfford = userPuntos >= p.pointCost;
            const delay = (i * 0.1).toFixed(1);
            return `
            <div class="reward-card glass-card-elevated rounded-3xl overflow-hidden flex flex-col animate-fade-in-up" style="animation-delay: ${delay}s;">
                <div class="h-44 relative overflow-hidden" style="background: linear-gradient(135deg, ${p.gradientFrom}, ${p.gradientTo});">
                    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 1px 1px, rgba(0,250,190,0.3) 1px, transparent 0); background-size: 16px 16px;"></div>
                    <span class="material-symbols-outlined text-white/10 text-[100px] absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">${p.iconName}</span>
                    <span class="absolute top-4 left-4 z-20 px-3 py-1.5 rounded-xl text-white text-[10px] font-bold uppercase tracking-wider backdrop-blur-sm" style="background: linear-gradient(135deg, #00fabe, #006c50);">${p.badgeText}</span>
                </div>
                <div class="p-6 flex-1 flex flex-col justify-between">
                    <div>
                        <h4 class="font-headline-md text-headline-md text-primary mb-2">${p.name}</h4>
                        <p class="font-body-md text-on-surface-variant text-sm mb-4 leading-relaxed">${p.description}</p>
                        <div class="flex items-center gap-2 mb-5">
                            <span class="material-symbols-outlined text-secondary-container text-lg" style="font-variation-settings: 'FILL' 1;">eco</span>
                            <span class="text-secondary font-bold font-label-md">${p.pointCost.toLocaleString()} EcoPuntos</span>
                        </div>
                    </div>
                    <button onclick="redeemPrize(${p.id}, ${p.pointCost}, '${p.name.replace(/'/g, "\\'")}')" 
                        ${!canAfford ? 'disabled title="No tienes suficientes puntos"' : ''}
                        class="w-full py-3.5 rounded-2xl font-label-md text-label-md transition-all duration-300 flex items-center justify-center gap-2 active:scale-[0.98] ${canAfford ? 'bg-secondary text-white hover:shadow-xl hover:shadow-secondary/30 hover:-translate-y-0.5' : 'bg-gray-200 text-gray-400 cursor-not-allowed'}">
                        <span class="material-symbols-outlined text-base">${canAfford ? 'shopping_cart' : 'lock'}</span>
                        ${canAfford ? 'Canjear Cupon' : 'Puntos insuficientes'}
                    </button>
                </div>
            </div>`;
        }).join('');
    }

    window.redeemPrize = async function(prizeId, cost, name) {
        if (!confirm(`Canjear "${name}" por ${cost} EcoPuntos?`)) return;

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers['RequestVerificationToken'] = token;

            const resp = await fetch(`/api/v1/prizes/${prizeId}/redeem`, {
                method: 'POST',
                headers: headers
            });

            const data = await resp.json();

            if (!resp.ok) {
                showToast(data.error || 'Error al canjear', 'error');
                return;
            }

            userPuntos = data.puntosRestantes;
            document.getElementById('puntos-display').textContent = userPuntos.toLocaleString();
            document.getElementById('user-rank-points').textContent = userPuntos.toLocaleString() + ' pts';

            showToast(`Canjeado: ${name}. Te quedan ${userPuntos.toLocaleString()} EcoPuntos`, 'success');
            loadPrizes();
        } catch (e) {
            showToast('Error de conexion', 'error');
        }
    };

    function showToast(message, type) {
        const container = document.getElementById('toast-container');
        const toast = document.getElementById('toast');
        const icon = document.getElementById('toast-icon');
        const msg = document.getElementById('toast-message');

        toast.className = type === 'success'
            ? 'px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-3 bg-secondary text-white'
            : 'px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-3 bg-error text-white';

        icon.textContent = type === 'success' ? 'check_circle' : 'error';
        msg.textContent = message;

        container.classList.remove('hidden');
        toast.classList.remove('translate-y-full', 'opacity-0');

        setTimeout(() => {
            toast.classList.add('translate-y-full', 'opacity-0');
            setTimeout(() => container.classList.add('hidden'), 300);
        }, 3000);
    }

    loadPrizes();
})();
</script>
