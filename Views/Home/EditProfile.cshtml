@{
    ViewData["Title"] = "Editar Perfil";
    var userPicture = User.FindFirst("Picture")?.Value ?? User.FindFirst("picture")?.Value ?? "https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y";
    var userName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "";
    var userEmail = User.Identity?.Name ?? ""; 
    var userPhone = User.FindFirst("Phone")?.Value ?? "+34 612 345 678";
    var userCity = User.FindFirst("City")?.Value ?? "Madrid, Espana";
    var userBio = User.FindFirst("Bio")?.Value ?? "Eco-entusiasta y conductora comprometida con el planeta desde 2023";
}

<div class="py-8 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="max-w-2xl mx-auto">
        <div class="glass-card rounded-3xl overflow-hidden">
            <!-- Decorative Header -->
            <div class="p-6 md:p-8 text-center relative" style="background: linear-gradient(135deg, #f5faf9 0%, #ffffff 100%);">
                <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#006c50 0.5px, transparent 0.5px); background-size: 15px 15px;"></div>
                <h2 class="font-display-lg text-headline-lg-mobile md:text-display-lg relative" style="color: #001915; letter-spacing: -0.02em;">Configuracion de Cuenta</h2>
                <p class="text-secondary relative font-body-md">Gestiona tu identidad y preferencias en la plataforma</p>
            </div>
            
            <div class="p-6 md:p-8 pt-0 relative">
                <form asp-action="EditProfile" method="post">
                    <!-- Profile Picture Section -->
                    <div class="text-center mb-8 -mt-12 relative z-10">
                        <div class="relative inline-block">
                            <div class="w-[140px] h-[140px] rounded-full p-1 bg-white shadow-xl inline-block border border-surface-container-low">
                                <img src="@userPicture" alt="Profile" id="profilePreview" class="w-full h-full rounded-full object-cover" />
                            </div>
                            <label for="photoUrl" class="absolute bottom-1 right-1 w-10 h-10 bg-secondary text-white rounded-full border-4 border-white flex items-center justify-center cursor-pointer hover:scale-110 transition-transform" title="Cambiar foto">
                                <span class="material-symbols-outlined text-lg">camera</span>
                            </label>
                        </div>
                        <div class="mt-4 px-5">
                            <label class="block font-label-md text-label-md text-secondary uppercase tracking-wider mb-2">URL de tu Foto de Perfil</label>
                            <input type="text" name="pictureUrl" id="photoUrl" class="w-full px-4 py-2 rounded-xl bg-surface-container-low border border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all text-sm" value="@userPicture" placeholder="https://ejemplo.com/mifoto.jpg" onchange="document.getElementById('profilePreview').src = this.value">
                            <p class="text-xs text-on-surface-variant mt-1">Pega el enlace de una imagen para actualizar tu foto.</p>
                        </div>
                    </div>

                    <div class="space-y-5">
                        <!-- Name -->
                        <div>
                            <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Nombre Completo</label>
                            <input type="text" name="fullName" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all font-body-md" value="@userName" placeholder="Tu nombre" required>
                        </div>

                        <!-- Email (Read-only) -->
                        <div>
                            <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Correo Electronico</label>
                            <input type="email" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border border-outline-variant outline-none font-body-md" value="@userEmail" readonly style="opacity: 0.6; cursor: not-allowed;">
                            <p class="text-xs text-on-surface-variant mt-1 flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">shield</span> El correo esta verificado y vinculado a tu cuenta.
                            </p>
                        </div>

                        <!-- Phone and City -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Telefono</label>
                                <input type="tel" name="phone" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all font-body-md" value="@userPhone" placeholder="Telefono">
                            </div>
                            <div>
                                <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Ciudad / Pais</label>
                                <input type="text" name="city" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all font-body-md" value="@userCity" placeholder="Ciudad">
                            </div>
                        </div>

                        <!-- Bio -->
                        <div>
                            <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Biografia</label>
                            <textarea name="bio" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all font-body-md" rows="4" placeholder="Biografia">@userBio</textarea>
                        </div>

                        <!-- Action Buttons -->
                        <div class="flex flex-col sm:flex-row gap-3 pt-4">
                            <button type="submit" class="flex-1 py-4 bg-secondary text-white rounded-xl font-label-md text-label-md font-bold hover:bg-on-secondary-fixed-variant transition-all flex items-center justify-center gap-2 active:scale-[0.98] shadow-lg shadow-secondary/20">
                                Guardar cambios
                                <span class="material-symbols-outlined text-lg">check_circle</span>
                            </button>
                            <a asp-action="Profile" class="px-8 py-4 rounded-xl bg-surface-container-low text-on-surface-variant font-label-md text-label-md font-bold hover:bg-surface-container-high transition-all text-center">
                                Cancelar
                            </a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
