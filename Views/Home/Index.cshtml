@model Proyecto_Grupo_gris.Models.DashboardViewModel

@{
    ViewData["Title"] = "Inicio";
}

<div class="dashboard-page container py-5">
    <section class="page-hero rounded-4 p-4 mb-5 shadow-sm">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-4 align-items-start">
            <div>
                <span class="hero-badge">Panel EcoRuta</span>
                <h1 class="hero-title">Controla tu ruta de reciclaje</h1>
                <p class="hero-description">Monitorea entregas, puntos y el impacto ambiental desde un tablero simple, moderno y eficiente.</p>
            </div>
            <div class="hero-stats p-4 rounded-4 bg-white shadow-sm">
                <span class="d-block text-uppercase text-muted small mb-2">En progreso</span>
                <h3 class="mb-1">A 500 metros</h3>
                <p class="mb-0 text-muted">Tu recolector está en camino.</p>
            </div>
        </div>
    </section>

    <div class="dashboard-topbar mb-3">
        <div>
            <p class="dashboard-section-label mb-1">Resumen</p>
            <h1 class="dashboard-title">Bienvenido a tu reciclaje</h1>
        </div>
    </div>

    <section class="dashboard-actions mb-4">
        <a class="btn btn-primary btn-lg me-2" href="#">Ver Mi Ruta</a>
        <a class="btn btn-outline-secondary btn-lg me-2" href="#">Mi Historial</a>
        <a class="btn btn-outline-secondary btn-lg" href="#">Premios</a>
    </section>

    <section class="dashboard-summary-card mb-3 p-4">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <div class="badge bg-white text-success mb-3">Esta semana</div>
                <div class="display-4 fw-bold mb-2">@Model.ReciclajeTotalKg kg</div>
                <p class="mb-1">Reciclaje total</p>
                <small class="text-white-75">@Model.Crecimiento</small>
            </div>
            <div class="dashboard-summary-icon">🍃</div>
        </div>
        <div class="progress rounded-pill mt-4" style="height: .5rem;">
            <div class="progress-bar bg-white" role="progressbar" style="width: 65%;" aria-valuenow="65" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
    </section>

    <section class="row g-3 dashboard-small-cards mb-3">
        <div class="col-6">
            <div class="card dashboard-small-card p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="dashboard-small-label">Entregas</span>
                    <span class="dashboard-small-icon">♻️</span>
                </div>
                <h2 class="dashboard-small-value mb-0">@Model.Entregas</h2>
            </div>
        </div>
        <div class="col-6">
            <div class="card dashboard-small-card p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="dashboard-small-label">Puntos</span>
                    <span class="dashboard-small-icon">🪙</span>
                </div>
                <h2 class="dashboard-small-value mb-0">@Model.Puntos</h2>
            </div>
        </div>
    </section>

    <section class="dashboard-map-card mb-3">
        <div class="dashboard-map-header px-4 pt-4">
            <div>
                <h2 class="h5 mb-1">Recorrido en tiempo real</h2>
                <p class="mb-0 text-white-50">Sigue el camión en ruta</p>
            </div>
            <a class="dashboard-map-link" href="#">Ver mapa</a>
        </div>
        <div class="dashboard-map-preview">
            <div class="dashboard-map-pin">📍</div>
        </div>
        <div class="dashboard-map-footer p-4 bg-white rounded-4 mt-n4 mx-3 mb-3 shadow-sm">
            <div class="d-flex align-items-center gap-3">
                <div class="dashboard-map-badge">🚚</div>
                <div>
                    <strong>@Model.RecolectorNombre</strong>
                    <p class="mb-0 text-muted">@Model.RecolectorDireccion</p>
                </div>
            </div>
            <div class="mt-3 text-muted"><small>@Model.Distancia</small></div>
        </div>
    </section>

    <section class="dashboard-impact row g-3 mb-5">
        <div class="col-md-4">
            <div class="dashboard-impact-card p-3">
                <p class="mb-2">CO₂ ahorrado</p>
                <h3>@Model.Co2AhorradoKg kg</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-impact-card p-3">
                <p class="mb-2">Árboles salvados</p>
                <h3>@Model.ArbolesSalvados</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-impact-card p-3">
                <p class="mb-2">Agua ahorrada</p>
                <h3>@Model.AguaAhorradaL L</h3>
            </div>
        </div>
    </section>
</div>
