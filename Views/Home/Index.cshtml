@{
    Layout = null;
    ViewData["Title"] = "EcoRuta - Login";
}

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>EcoRuta</title>

<style>
    body {
        margin: 0;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #dcfce7, #bbf7d0);
        font-family: "Segoe UI", sans-serif;
    }

    .container-login {
        text-align: center;
        width: 100%;
        max-width: 350px;
    }

    .logo h1 {
        color: #166534;
        font-size: 32px;
        margin: 0;
    }

    .logo p {
        color: #4b5563;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .card {
        background: white;
        padding: 25px;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        text-align: left;
    }

    .card h2 {
        text-align: center;
        color: #166534;
        margin-bottom: 20px;
    }

    .input-group {
        margin-bottom: 15px;
    }

    input {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        outline: none;
    }

    input:focus {
        border-color: #166534;
        box-shadow: 0 0 0 2px rgba(22,101,52,0.2);
    }

    .btn-login {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 12px;
        background-color: #166534;
        color: white;
        cursor: pointer;
    }

    .btn-login:hover {
        background-color: #14532d;
    }

    .footer-text {
        text-align: center;
        margin-top: 15px;
        font-size: 13px;
    }

    .footer-text a {
        color: #166534;
        text-decoration: none;
    }
</style>
</head>

<body>

<div class="container-login">
    <div class="logo">
        <div style="font-size:28px;">🌱</div>
        <h1>EcoRuta</h1>
        <p>Reciclaje inteligente</p>
    </div>

    <div class="card">
        <h2>Iniciar Sesión</h2>

        <form method="post">
            <div class="input-group">
                <input type="email" placeholder="Correo electrónico" required>
            </div>

            <div class="input-group">
                <input type="password" placeholder="Contraseña" required>
            </div>

            <button class="btn-login">Ingresar</button>
        </form>

        <div class="footer-text">
            ¿No tienes cuenta? <a href="#">Regístrate</a>
        </div>
    </div>
</div>

</body>
</html>