@model Proyecto_Grupo_gris.Models.DashboardViewModel

@{
    ViewData["Title"] = "Inicio";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style>
    .map-instruction-badge {
        position: absolute;
        bottom: 15px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(15, 30, 26, 0.85);
        color: white;
        padding: 0.45rem 1.2rem;
        border-radius: 9999px;
        font-size: 0.75rem;
        font-weight: 600;
        z-index: 1000;
        backdrop-filter: blur(5px);
        pointer-events: none;
        box-shadow: 0 6px 18px rgba(0,0,0,0.15);
        border: 1px solid rgba(255,255,255,0.15);
        transition: opacity 0.4s ease;
    }
    .gps-alert {
        position: absolute;
        top: 15px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(254, 243, 199, 0.95);
        color: #92400e;
        border: 1px solid #fde68a;
        padding: 0.5rem 1.2rem;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
        z-index: 1000;
        backdrop-filter: blur(8px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        gap: 1rem;
        max-width: 90%;
        transition: opacity 0.3s ease;
    }
    .btn-close-alert {
        background: none; border: none; color: #92400e;
        font-size: 1.1rem; font-weight: bold; cursor: pointer; padding: 0; line-height: 1;
    }
    .btn-close-alert:hover { color: #78350f; }
    .map-news { margin-top: 18px; padding: 12px; background: #ffffff; border-radius: 8px; box-shadow: 0 2px 6px rgba(16,185,129,0.06); }
    .map-news h6 { font-weight: 700; margin-bottom: 12px; color: #001915; }
    .map-news .news-item { display: flex; gap: 12px; align-items: flex-start; margin-bottom: 12px; padding: 10px; border-radius: 10px; background: #f5faf9; }
    .map-news .news-thumb { width: 76px; height: 56px; border-radius: 8px; overflow: hidden; background: linear-gradient(180deg, #f0f5f4, #ffffff); display: flex; align-items: center; justify-content: center; flex: 0 0 76px; }
    .map-news .news-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .map-news .news-content a { display: block; font-weight: 700; color: #001915; text-decoration: none; word-break: break-word; }
    .map-news .news-content a:hover { text-decoration: underline; color: #006c50; }
    .map-news .news-meta { color: #717977; font-size: 0.82rem; margin-top: 6px; }
    @@media (max-width: 767px) { .map-news .news-thumb { display: none; } }
</style>

<div class="py-6 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">

    <!-- Top Row: Welcome + Weekly Stats -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6">

        <!-- Welcome Card (Left) -->
        <div class="lg:col-span-4 rounded-3xl p-8 flex flex-col justify-between animate-fade-in-up relative overflow-hidden min-h-[380px]" style="background: linear-gradient(160deg, #f0f5f4 0%, #e4e9e8 100%); border: 1px solid rgba(0,108,80,0.06);">
            <div class="relative z-10">
                <span class="inline-block px-4 py-1.5 rounded-full bg-secondary text-white text-[11px] font-bold uppercase tracking-[0.1em] mb-5">Panel EcoRuta</span>
                <h1 class="text-[32px] md:text-[36px] font-extrabold text-on-surface leading-[1.1] tracking-tight mb-4" style="font-family: 'Hanken Grotesk', sans-serif;">Controla tu ruta de reciclaje</h1>
                <p class="text-on-surface-variant font-body-md text-[15px] leading-relaxed max-w-[280px]">Monitorea entregas, puntos y el impacto ambiental desde un tablero simple, moderno y eficiente.</p>
            </div>
            <!-- Truck illustration area -->
            <div class="relative mt-8 z-10">
                <div class="px-4 py-2 rounded-full bg-on-surface/90 text-white text-[12px] font-bold inline-flex items-center gap-1.5 mb-3 ml-4">
                    <span class="material-symbols-outlined text-sm">route</span> Ruta
                </div>
                <div class="rounded-2xl p-4 flex items-center justify-center" style="background: linear-gradient(135deg, #d5e8dc 0%, #c1dbc7 100%);">
                    <div class="flex items-end gap-0">
                        <!-- Truck SVG -->
                        <svg width="140" height="70" viewBox="0 0 140 70" fill="none">
                            <!-- Truck body -->
                            <rect x="10" y="15" width="80" height="40" rx="6" fill="#1a5c2e"/>
                            <rect x="12" y="17" width="76" height="36" rx="4" fill="#1a5c2e"/>
                            <!-- Cab -->
                            <rect x="90" y="25" width="35" height="30" rx="6" fill="#0d3d1c"/>
                            <rect x="95" y="28" width="18" height="14" rx="3" fill="#86d4a0" opacity="0.5"/>
                            <!-- Wheels -->
                            <circle cx="35" cy="58" r="8" fill="#333"/>
                            <circle cx="35" cy="58" r="4" fill="#666"/>
                            <circle cx="75" cy="58" r="8" fill="#333"/>
                            <circle cx="75" cy="58" r="4" fill="#666"/>
                            <circle cx="108" cy="58" r="8" fill="#333"/>
                            <circle cx="108" cy="58" r="4" fill="#666"/>
                            <!-- EcoRuta logo on truck -->
                            <circle cx="50" cy="35" r="6" fill="#00fabe" opacity="0.6"/>
                            <text x="50" y="37" text-anchor="middle" fill="#0d3d1c" font-size="6" font-weight="bold">♻</text>
                        </svg>
                    </div>
                </div>
            </div>
            <!-- Decorative circles -->
            <div class="absolute top-0 right-0 w-48 h-48 bg-secondary/5 rounded-full blur-3xl"></div>
            <div class="absolute bottom-20 left-0 w-32 h-32 bg-secondary-container/10 rounded-full blur-2xl"></div>
        </div>

        <!-- Weekly Stats Card (Right) -->
        <div class="lg:col-span-8 rounded-3xl p-8 flex flex-col justify-between animate-fade-in-up relative overflow-hidden min-h-[380px]" style="animation-delay: 0.1s; background: linear-gradient(145deg, #0f2e2a, #001915, #001915); border: 1px solid rgba(0,250,190,0.08);">
            <!-- Decorative -->
            <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, rgba(0,250,190,0.2) 1px, transparent 0); background-size: 30px 30px;"></div>
            <div class="absolute top-0 right-0 w-96 h-96 bg-secondary/10 rounded-full blur-3xl -translate-y-1/3 translate-x-1/4"></div>
            <div class="absolute bottom-0 left-0 w-72 h-72 bg-secondary-container/8 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4"></div>

            <!-- Chart icon -->
            <div class="absolute top-8 right-8 w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-secondary-container/70 text-2xl">monitoring</span>
            </div>

            <div class="relative z-10">
                <span class="inline-block px-4 py-1.5 rounded-full border border-white/15 text-inverse-primary/60 text-[12px] font-semibold mb-6 bg-white/5">Esta semana</span>

                <div class="flex items-baseline gap-3 mb-2">
                    <span class="text-[64px] md:text-[80px] font-extrabold text-white leading-none tracking-tight" style="font-family: 'Hanken Grotesk', sans-serif;"><span id="stat-totalKg">@Model.ReciclajeTotalKg</span></span>
                    <span class="text-inverse-primary/30 font-body-lg text-[22px] font-medium">kg</span>
                </div>
                <p class="text-inverse-primary/50 font-body-md text-[15px] mb-2">Reciclaje total acumulado</p>
                <p class="text-secondary-container font-semibold text-[14px] flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-lg">trending_up</span>
                    +15% de incremento vs. semana anterior
                </p>
            </div>

            <!-- Progress bar -->
            <div class="relative z-10 mt-8">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-inverse-primary/40 text-[13px] font-semibold">Progreso semanal</span>
                    <span class="text-white font-bold text-[15px]" style="font-family: 'Hanken Grotesk', sans-serif;">75% Meta</span>
                </div>
                <div class="w-full h-3 bg-white/5 rounded-full overflow-hidden">
                    <div class="h-full rounded-full transition-all duration-1000" style="width: 75%; background: linear-gradient(90deg, #006c50, #00fabe, #36ffc4); box-shadow: 0 0 20px rgba(0,250,190,0.4);"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Row: Stat Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Entregas -->
        <div class="rounded-3xl p-6 flex items-center gap-4 animate-fade-in-up relative overflow-hidden group transition-all duration-300 hover:-translate-y-1 hover:shadow-lg" style="animation-delay: 0.15s; background: #ffffff; border: 1px solid rgba(0,108,80,0.06);">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0" style="background: rgba(0,108,80,0.08);">
                <span class="material-symbols-outlined text-secondary text-2xl">local_shipping</span>
            </div>
            <div>
                <span class="text-on-surface-variant text-[11px] font-bold uppercase tracking-[0.15em] block mb-1">Entregas</span>
                <span class="text-[32px] font-extrabold text-on-surface leading-none block" style="font-family: 'Hanken Grotesk', sans-serif;" id="stat-entregas">@Model.Entregas</span>
                <span class="text-secondary text-[13px] font-medium mt-1 block">Servicios completados</span>
            </div>
        </div>

        <!-- Puntos -->
        <div class="rounded-3xl p-6 flex items-center gap-4 animate-fade-in-up relative overflow-hidden group transition-all duration-300 hover:-translate-y-1 hover:shadow-lg" style="animation-delay: 0.2s; background: #ffffff; border: 1px solid rgba(0,108,80,0.06);">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0" style="background: rgba(99,102,241,0.08);">
                <span class="material-symbols-outlined text-[#6366f1] text-2xl" style="font-variation-settings: 'FILL' 1;">stars</span>
            </div>
            <div>
                <span class="text-on-surface-variant text-[11px] font-bold uppercase tracking-[0.15em] block mb-1">Puntos</span>
                <span class="text-[32px] font-extrabold text-on-surface leading-none block" style="font-family: 'Hanken Grotesk', sans-serif;" id="stat-puntos">@Model.Puntos</span>
                <span class="text-secondary text-[13px] font-medium mt-1 block">Para canjear premios</span>
            </div>
        </div>

        <!-- Distancia -->
        <div class="rounded-3xl p-6 flex items-center gap-4 animate-fade-in-up relative overflow-hidden group transition-all duration-300 hover:-translate-y-1 hover:shadow-lg" style="animation-delay: 0.25s; background: #ffffff; border: 1px solid rgba(0,108,80,0.06);">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0" style="background: rgba(0,108,80,0.08);">
                <span class="material-symbols-outlined text-secondary text-2xl">route</span>
            </div>
            <div>
                <span class="text-on-surface-variant text-[11px] font-bold uppercase tracking-[0.15em] block mb-1">Distancia</span>
                <span class="text-[32px] font-extrabold text-on-surface leading-none block" style="font-family: 'Hanken Grotesk', sans-serif;" id="camion-distancia">@Model.Distancia</span>
                <span class="text-secondary text-[13px] font-medium mt-1 block">Ruta del recolector</span>
            </div>
        </div>

        <!-- Eco Creditos -->
        <div class="rounded-3xl p-6 flex items-center gap-4 animate-fade-in-up relative overflow-hidden group transition-all duration-300 hover:-translate-y-1 hover:shadow-lg" style="animation-delay: 0.3s; background: linear-gradient(135deg, #001915, #0f2e2a); border: 1px solid rgba(0,250,190,0.1);">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0 bg-white/10">
                <span class="material-symbols-outlined text-secondary-container text-2xl" style="font-variation-settings: 'FILL' 1;">eco</span>
            </div>
            <div>
                <span class="text-inverse-primary/40 text-[11px] font-bold uppercase tracking-[0.15em] block mb-1">EcoCreditos</span>
                <span class="text-[32px] font-extrabold text-white leading-none block" style="font-family: 'Hanken Grotesk', sans-serif;" id="stat-puntos-alt">@Model.Puntos</span>
                <a asp-controller="Home" asp-action="Premios" class="text-secondary-container text-[13px] font-semibold mt-1 block hover:underline">Canjear premios →</a>
            </div>
        </div>
    </div>

    <!-- Map + Sidebar Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

        <!-- Real-time Map Section -->
        <div class="md:col-span-12 lg:col-span-9 glass-card-elevated rounded-3xl overflow-hidden min-h-[500px] flex flex-col animate-fade-in-up" style="animation-delay: 0.15s;">
            <div class="p-6 border-b border-outline-variant/20 flex justify-between items-center" style="background: linear-gradient(135deg, rgba(0,108,80,0.03), rgba(0,250,190,0.02));">
                <div class="flex items-center gap-3">
                    <div class="w-11 h-11 rounded-2xl bg-secondary/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-secondary text-xl">distance</span>
                    </div>
                    <div>
                        <h3 class="font-headline-md text-headline-md text-on-surface">Ruta en Tiempo Real</h3>
                        <p class="text-on-surface-variant text-sm" id="camion-direccion">@Model.RecolectorDireccion</p>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <button id="btn-re-simular" class="px-4 py-2.5 rounded-xl border border-secondary/20 text-secondary font-label-md text-label-md hover:bg-secondary/5 transition-all duration-300 flex items-center gap-1 hover:shadow-md">
                        <span class="material-symbols-outlined text-lg">refresh</span> Reiniciar
                    </button>
                    <button id="btn-mi-gps" class="px-4 py-2.5 rounded-xl bg-secondary text-white font-label-md text-label-md transition-all duration-300 flex items-center gap-1 hover:shadow-lg hover:shadow-secondary/30 hover:-translate-y-0.5 active:scale-[0.98]">
                        <span class="material-symbols-outlined text-lg">my_location</span> Mi GPS
                    </button>
                </div>
            </div>
            <div class="flex-1 relative bg-surface-variant" style="min-height: 400px;">
                <div id="map" style="height: 100%; width: 100%;"></div>
                <div class="map-instruction-badge" id="map-tip">
                    <span class="material-symbols-outlined text-sm align-middle mr-1">info</span> Haz clic en cualquier parte del mapa para cambiar tu ubicacion
                </div>
                <div id="gps-alert-banner" class="gps-alert" style="display: none;">
                    <span id="gps-alert-text">Cargando ubicacion...</span>
                    <button id="btn-cerrar-alert" class="btn-close-alert">&times;</button>
                </div>
            </div>
            <!-- Map notation bar -->
            <div class="p-4 border-t border-outline-variant/20 flex items-center gap-4" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(8px);">
                <div class="w-11 h-11 rounded-2xl bg-secondary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-secondary text-xl">local_shipping</span>
                </div>
                <div class="flex-1">
                    <div class="font-bold text-on-surface text-sm" id="notation-name">@Model.RecolectorNombre</div>
                    <div class="text-xs text-on-surface-variant" id="notation-desc">@Model.Distancia — @Model.RecolectorDireccion</div>
                </div>
                <div class="text-right">
                    <div class="text-secondary font-bold text-sm flex items-center gap-1" id="notation-status">
                        <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span> En ruta
                    </div>
                    <div class="text-[11px] text-outline" id="notation-updated">Actualizado ahora</div>
                </div>
            </div>
            <!-- News -->
            <div id="map-news" class="map-news mx-4 mb-4">
                <h6 class="mb-2 flex items-center gap-2">
                    <span class="material-symbols-outlined text-secondary text-lg">article</span> Noticias ambientales
                </h6>
                <ul id="map-news-list" class="list-none m-0 p-0">
                    <li class="text-on-surface-variant">Cargando noticias...</li>
                </ul>
            </div>
        </div>

        <!-- Right Column: Status & Actions -->
        <div class="md:col-span-12 lg:col-span-3 flex flex-col gap-6">
            <!-- Service Status -->
            <div class="glass-card-elevated rounded-3xl p-6 flex-1 flex flex-col animate-fade-in-up" style="animation-delay: 0.2s;">
                <div class="flex items-center justify-between mb-4">
                    <span class="font-label-md text-label-md uppercase tracking-wider text-on-surface-variant">Estado del Servicio</span>
                    <span class="px-3 py-1.5 rounded-xl bg-secondary/10 text-secondary font-label-md text-label-md flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span> En curso
                    </span>
                </div>
                <h3 class="font-headline-md text-headline-md mb-2 text-on-surface" id="camion-distancia-prog">A 500 metros</h3>
                <p class="text-on-surface-variant text-sm mb-6">Tu recolector esta cerca. Prepara tus materiales.</p>
                <!-- Route tracker -->
                <div class="flex items-center mt-auto">
                    <div class="w-6 h-6 rounded-full bg-secondary flex-shrink-0 relative z-2" style="box-shadow: 0 0 0 6px rgba(0, 108, 80, 0.2);"></div>
                    <div class="flex-1 h-1.5 bg-surface-container-high rounded-full mx-2 overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-300 route-line" style="width: 50%; background: linear-gradient(90deg, #006c50 50%, #e4e9e8 50%);"></div>
                    </div>
                    <div class="w-12 h-12 rounded-2xl bg-white border-2 border-outline-variant flex items-center justify-center shrink-0 route-truck-end transition-all duration-300">
                        <span class="material-symbols-outlined text-on-surface-variant">home</span>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="glass-card-elevated rounded-3xl p-6 animate-fade-in-up" style="animation-delay: 0.25s;">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-secondary text-xl">bolt</span>
                    <span class="font-label-md text-label-md uppercase tracking-wider text-secondary">Acciones Rapidas</span>
                </div>
                <h3 class="font-headline-md text-headline-md mb-5 text-on-surface">Que deseas hacer?</h3>
                <div class="space-y-3">
                    <button class="w-full text-left p-4 rounded-2xl bg-secondary text-white font-bold flex items-center gap-3 transition-all duration-300 hover:shadow-xl hover:shadow-secondary/30 hover:-translate-y-0.5 active:scale-[0.98]">
                        <span class="material-symbols-outlined text-xl">report</span> Reportar un problema
                    </button>
                    <button class="w-full text-left p-4 rounded-2xl glass-card font-bold flex items-center gap-3 hover:bg-white/80 transition-all duration-300 hover:-translate-y-0.5 group">
                        <span class="material-symbols-outlined text-secondary text-xl group-hover:scale-110 transition-transform">history</span> Historial de recolecciones
                    </button>
                    <a asp-controller="Home" asp-action="Premios" class="w-full text-left p-4 rounded-2xl glass-card font-bold flex items-center gap-3 hover:bg-white/80 transition-all duration-300 hover:-translate-y-0.5 group block">
                        <span class="material-symbols-outlined text-secondary text-xl group-hover:scale-110 transition-transform">redeem</span> Catalogo de Premios
                    </a>
                </div>
            </div>

            <!-- Eco Tip -->
            <div class="relative p-6 rounded-3xl overflow-hidden animate-fade-in-up" style="animation-delay: 0.3s; background: linear-gradient(135deg, #006c50, #00513c, #001915);">
                <div class="absolute inset-0 opacity-15" style="background-image: radial-gradient(circle at 1px 1px, rgba(0,250,190,0.3) 1px, transparent 0); background-size: 16px 16px;"></div>
                <div class="absolute top-0 right-0 w-32 h-32 bg-secondary-container/15 rounded-full blur-2xl -translate-y-1/2 translate-x-1/3"></div>
                <div class="relative z-10">
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-9 h-9 rounded-xl bg-white/15 flex items-center justify-center">
                            <span class="material-symbols-outlined text-secondary-container text-lg" style="font-variation-settings: 'FILL' 1;">lightbulb</span>
                        </div>
                        <span class="font-bold text-sm text-white">Eco-Tip del Dia</span>
                    </div>
                    <p class="text-white/70 text-sm leading-relaxed">Limpia y aplasta tus botellas de plastico para ahorrar espacio y facilitar el trabajo de los recicladores.</p>
                </div>
                <div class="absolute -right-4 -bottom-4 opacity-10">
                    <span class="material-symbols-outlined text-secondary-container" style="font-size: 120px;" style="font-variation-settings: 'FILL' 1;">eco</span>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Default User location (Lima Centro fallback)
            var userLat = -12.046374;
            var userLng = -77.042793;

            // Initialize map centered on default location
            var map = L.map('map').setView([userLat, userLng], 14);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // Custom Premium Glowing Markers using Leaflet divIcon
            var homeIcon = L.divIcon({
                className: 'custom-home-icon',
                html: `<div class="home-pulse-container">
                         <div class="home-pulse"></div>
                         <div class="home-marker-dot">🏠</div>
                       </div>`,
                iconSize: [40, 40],
                iconAnchor: [20, 20]
            });

            var truckIcon = L.divIcon({
                className: 'custom-truck-icon',
                html: `<div class="truck-marker-container">
                         <div class="truck-pulse"></div>
                         <div class="truck-marker-dot">🚚</div>
                       </div>`,
                iconSize: [42, 42],
                iconAnchor: [21, 21]
            });

            // Final destination icon & marker (declared early to avoid race conditions)
            var finalIcon = L.divIcon({
                className: 'custom-final-icon',
                html: `<div class="final-flag-container"><div class="final-flag">🏁</div></div>`,
                iconSize: [32, 32],
                iconAnchor: [16, 16]
            });

            var finalMarker = null;

            // Markers and Path variables
            var userMarker = L.marker([userLat, userLng], { icon: homeIcon }).addTo(map);
            userMarker.bindPopup("<b>Tu Ubicación (Casa)</b><br>Aquí llegará el camión.").openPopup();

            var truckMarker = L.marker([userLat, userLng], { icon: truckIcon }).addTo(map);
            truckMarker.bindPopup("<b>Camión Recolector</b><br>Buscando ruta...");

            var routePolyline = L.polyline([], {
                color: '#006c50',
                weight: 4,
                opacity: 0.65,
                dashArray: '8, 12'
            }).addTo(map);

            var routeCoordinates = [];
            var currentIndex = 0;
            var simulationInterval = null;
            var simulationSessionId = 0;

            // Location alert handlers
            function showLocationAlert(message) {
                var alertBanner = document.getElementById('gps-alert-banner');
                var alertText = document.getElementById('gps-alert-text');
                if (alertBanner && alertText) {
                    alertText.innerHTML = message;
                    alertBanner.style.display = 'flex';
                    alertBanner.style.opacity = '1';
                }
            }

            function hideLocationAlert() {
                var alertBanner = document.getElementById('gps-alert-banner');
                if (alertBanner) {
                    alertBanner.style.opacity = '0';
                    setTimeout(function() {
                        alertBanner.style.display = 'none';
                    }, 300);
                }
            }

            // Helper to interpolate points smoothly for fluid marker movement
            function interpolatePoints(p1, p2, steps) {
                var points = [];
                for (var i = 0; i <= steps; i++) {
                    var t = i / steps;
                    var lat = p1[0] + (p2[0] - p1[0]) * t;
                    var lng = p1[1] + (p2[1] - p1[1]) * t;
                    points.push([lat, lng]);
                }
                return points;
            }

            // Fallback grid route generator (if routing API fails or is offline)
            function generateMockRoute(start, end) {
                var lat1 = start[0], lng1 = start[1];
                var lat2 = end[0], lng2 = end[1];
                var dLat = lat2 - lat1;
                var dLng = lng2 - lng1;

                var c1 = [lat1 + dLat * 0.35, lng1];
                var c2 = [lat1 + dLat * 0.35, lng1 + dLng * 0.7];
                var c3 = [lat2, lng1 + dLng * 0.7];

                var path = [];
                path = path.concat(interpolatePoints(start, c1, 20));
                path = path.concat(interpolatePoints(c1, c2, 20));
                path = path.concat(interpolatePoints(c2, c3, 20));
                path = path.concat(interpolatePoints(c3, end, 20));

                var uniquePath = [];
                for (var i = 0; i < path.length; i++) {
                    if (i === 0 || path[i][0] !== path[i-1][0] || path[i][1] !== path[i-1][1]) {
                        uniquePath.push(path[i]);
                    }
                }
                return uniquePath;
            }

            // Fetch real driving route from free public OSRM API
            function getRealStreetRoute(start, end, callback) {
                var waypoints = null;
                var cb = callback;

                if (typeof cb === 'undefined' && typeof end === 'function') {
                    cb = end;
                }

                if (Array.isArray(start) && start.length > 0 && Array.isArray(start[0])) {
                    waypoints = start;
                } else {
                    waypoints = [start, end];
                }

                var coordPairs = waypoints.map(function(pt) {
                    var lat = pt[0], lng = pt[1];
                    return lng + ',' + lat;
                }).join(';');

                var url = `https://router.project-osrm.org/route/v1/driving/${coordPairs}?overview=full&geometries=geojson`;

                fetch(url)
                    .then(response => {
                        if (!response.ok) throw new Error('OSRM network response not ok: ' + response.status);
                        return response.json();
                    })
                    .then(data => {
                        if (data && (data.code === 'Ok' || data.code === 'OK' || data.routes) && data.routes && data.routes.length > 0) {
                            var rawCoords = data.routes[0].geometry.coordinates.map(function (c) {
                                return [c[1], c[0]];
                            });

                            var smoothed = [];
                            for (var i = 0; i < rawCoords.length - 1; i++) {
                                var p1 = rawCoords[i];
                                var p2 = rawCoords[i+1];
                                smoothed = smoothed.concat(interpolatePoints(p1, p2, 5));
                            }

                            var finalCoords = [];
                            for (var j = 0; j < smoothed.length; j++) {
                                if (j === 0 || smoothed[j][0] !== smoothed[j-1][0] || smoothed[j][1] !== smoothed[j-1][1]) {
                                    finalCoords.push(smoothed[j]);
                                }
                            }
                            cb(finalCoords);
                        } else {
                            cb(generateMockRoute(waypoints[0], waypoints[waypoints.length-1]));
                        }
                    })
                    .catch(error => {
                        console.error("Error calling OSRM server. Falling back to grid route:", error);
                        cb(generateMockRoute(waypoints[0], waypoints[waypoints.length-1]));
                    });
            }

            // Core simulation loop
            function startSimulation() {
                if (simulationInterval) {
                    clearInterval(simulationInterval);
                }

                simulationSessionId++;
                var currentSession = simulationSessionId;

                if (finalMarker) { map.removeLayer(finalMarker); finalMarker = null; }

                document.querySelector('.route-truck-end').classList.remove('arrived');

                var angleStart = Math.random() * Math.PI * 2;
                var startLat = userLat + Math.sin(angleStart) * (0.007 + Math.random() * 0.003);
                var startLng = userLng + Math.cos(angleStart) * (0.007 + Math.random() * 0.003);

                var angleEnd = angleStart + Math.PI * (0.6 + Math.random() * 0.8);
                var endLat   = userLat + Math.sin(angleEnd) * (0.004 + Math.random() * 0.003);
                var endLng   = userLng + Math.cos(angleEnd) * (0.004 + Math.random() * 0.003);

                finalMarker = L.marker([endLat, endLng], { icon: finalIcon }).addTo(map);
                finalMarker.bindPopup("<b>Destino Final del Camión</b><br>Fin de la ruta de recolección.");

                truckMarker.setLatLng([startLat, startLng]);
                truckMarker.setPopupContent("<b>Camión Recolector</b><br>Calculando ruta real...");
                document.getElementById('camion-direccion').innerText = "Trazando ruta por calles reales...";

                var passedHome       = false;
                var homePassedAlerted = false;
                var frozenForPassby  = false;

                getRealStreetRoute(
                    [[startLat, startLng], [userLat, userLng], [endLat, endLng]],
                    function (allCoords) {
                        if (currentSession !== simulationSessionId) return;

                        if (!allCoords || !Array.isArray(allCoords) || allCoords.length === 0) {
                            allCoords = generateMockRoute([startLat, startLng], [endLat, endLng]);
                        }

                        routeCoordinates = allCoords;
                        routePolyline.setLatLngs(routeCoordinates);

                        try {
                            if (routeCoordinates.length > 0) {
                                map.fitBounds(L.latLngBounds([
                                    [startLat, startLng],
                                    [userLat,  userLng],
                                    [endLat,   endLng]
                                ]), { padding: [60, 60] });
                            }
                        } catch (err) {
                            console.warn('Failed to fit bounds:', err);
                        }

                        currentIndex = 0;

                        simulationInterval = setInterval(function () {
                            if (currentIndex >= routeCoordinates.length) {
                                clearInterval(simulationInterval);
                                truckMarker.setLatLng([endLat, endLng]);
                                truckMarker.bindPopup("<b>Fin de Ruta</b><br>El camión completó su recorrido.").openPopup();
                                document.querySelector('.route-truck-end').classList.add('arrived');
                                document.getElementById('camion-distancia').innerText = "Ruta completa";
                                document.getElementById('camion-distancia-prog').innerText = "Ruta finalizada";
                                document.getElementById('camion-direccion').innerText = "Ruta de recolección completada";
                                document.querySelector('.route-line').style.background = 'linear-gradient(90deg, #006c50 100%, #e4e9e8 100%)';
                                return;
                            }

                            if (frozenForPassby) { currentIndex++; return; }

                            var currentPos = routeCoordinates[currentIndex];
                            truckMarker.setLatLng(currentPos);

                            var progress = (currentIndex / (routeCoordinates.length - 1)) * 100;
                            document.querySelector('.route-line').style.background =
                                'linear-gradient(90deg, #006c50 ' + progress + '%, #e4e9e8 ' + progress + '%)';

                            var distToHome = Math.round(map.distance([userLat, userLng], currentPos));

                            if (!passedHome) {
                                document.getElementById('camion-distancia').innerText = "A " + distToHome + " m";
                                document.getElementById('camion-distancia-prog').innerText = "A " + distToHome + " metros";
                                truckMarker.setPopupContent("<b>Camión Recolector</b><br>Distancia a tu casa: " + distToHome + " m");

                                if (distToHome > 850) {
                                    document.getElementById('camion-direccion').innerText = "En ruta principal por calles...";
                                } else if (distToHome > 450) {
                                    document.getElementById('camion-direccion').innerText = "Transitando por avenidas aledañas...";
                                } else if (distToHome > 150) {
                                    document.getElementById('camion-direccion').innerText = "Ingresando a tu cuadra...";
                                } else {
                                    document.getElementById('camion-direccion').innerText = "Casi frente a tu casa...";
                                }

                                if (distToHome <= 40 && !homePassedAlerted) {
                                    homePassedAlerted = true;
                                    passedHome        = true;
                                    frozenForPassby   = true;

                                    document.getElementById('camion-direccion').innerText = "Frente a tu casa";
                                    document.getElementById('camion-distancia').innerText = "Aquí!";
                                    document.getElementById('camion-distancia-prog').innerText = "Frente a tu casa!";
                                    truckMarker.setPopupContent("<b>¡Frente a tu casa!</b><br>Entrega tus materiales reciclables.").openPopup();

                                    setTimeout(function () {
                                        frozenForPassby = false;
                                        document.getElementById('camion-direccion').innerText = "El camión ya pasó por su ubicación";
                                        document.getElementById('camion-distancia').innerText = "Pasó ✓";
                                        document.getElementById('camion-distancia-prog').innerText = "Ya pasó por tu casa";
                                        truckMarker.setPopupContent("<b>Camión Recolector</b><br>Siguiendo ruta al destino final.");
                                    }, 2500);
                                }

                            } else {
                                var distToEnd = Math.round(map.distance([endLat, endLng], currentPos));
                                document.getElementById('camion-distancia').innerText = "Pasó ✓";
                                document.getElementById('camion-distancia-prog').innerText = "Ya pasó por tu casa";
                                document.getElementById('camion-direccion').innerText = "Continuando ruta (" + distToEnd + " m al destino)";
                                truckMarker.setPopupContent("<b>Camión Recolector</b><br>A " + distToEnd + " m del destino final.");
                            }

                            currentIndex++;
                        }, 350);
                    }
                );
            }

            // Browser GPS detection with IP Fallback
            function detectUserLocation() {
                var gpsOptions = { enableHighAccuracy: true, timeout: 6000, maximumAge: 0 };

                if (!navigator.geolocation) {
                    showLocationAlert("Tu navegador no soporta GPS. Detectando ubicación por red (IP)...");
                    fetchIPLocation();
                    return;
                }

                var isSecureContext = window.isSecureContext || window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
                if (!isSecureContext) {
                    showLocationAlert("GPS desactivado por seguridad (requiere HTTPS o localhost). Detectando por IP...");
                    fetchIPLocation();
                    return;
                }

                navigator.geolocation.getCurrentPosition(
                    function (position) {
                        userLat = position.coords.latitude;
                        userLng = position.coords.longitude;

                        userMarker.setLatLng([userLat, userLng]);
                        userMarker.bindPopup("<b>Tu Ubicación (GPS)</b><br>Precisión exacta de tu casa.").openPopup();
                        
                        map.setView([userLat, userLng], 15);
                        startSimulation();

                        hideLocationAlert();

                        var tip = document.getElementById('map-tip');
                        if (tip) tip.style.opacity = '0';
                    },
                    function (error) {
                        console.warn("GPS detection failed, code: " + error.code);
                        var msg = "No pudimos acceder a tu GPS. Detectando ubicación aproximada por red...";
                        if (error.code === error.PERMISSION_DENIED) {
                            msg = "Permiso de GPS denegado. Detectando ubicación por red (IP). Habilita el GPS para precisión exacta.";
                        }
                        showLocationAlert(msg);
                        fetchIPLocation();
                    },
                    gpsOptions
                );
            }

            // Fetch approximate location using free IP Geolocation API
            function fetchIPLocation() {
                fetch('https://ipapi.co/json/')
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.latitude && data.longitude) {
                            userLat = data.latitude;
                            userLng = data.longitude;

                            userMarker.setLatLng([userLat, userLng]);
                            userMarker.bindPopup(`<b>Tu Ubicación aproximada (IP)</b><br>Ciudad: ${data.city || 'Desconocida'}`).openPopup();

                            map.setView([userLat, userLng], 14);
                            startSimulation();

                            document.getElementById('camion-direccion').innerText = `Ubicación detectada: ${data.city || 'Tu red'}, ${data.country_name || ''}`;
                        } else {
                            useFinalFallback();
                        }
                    })
                    .catch(err => {
                        console.warn("IP Geolocation API failed. Using final fallback:", err);
                        useFinalFallback();
                    });
            }

            function useFinalFallback() {
                userMarker.setLatLng([userLat, userLng]);
                userMarker.bindPopup("<b>Ubicación de Simulación</b><br>Haz clic en cualquier punto del mapa para ubicar tu casa.").openPopup();
                map.setView([userLat, userLng], 14);
                startSimulation();
            }

            // Map interactive clicks to relocate house
            map.on('click', function (e) {
                userLat = e.latlng.lat;
                userLng = e.latlng.lng;

                userMarker.setLatLng([userLat, userLng]);
                userMarker.bindPopup("<b>Ubicación Seleccionada</b><br>El camión vendrá aquí.").openPopup();

                startSimulation();

                var tip = document.getElementById('map-tip');
                if (tip) tip.style.opacity = '0';
            });

            // Button Event Listeners
            document.getElementById('btn-re-simular').addEventListener('click', function (e) {
                e.preventDefault();
                startSimulation();
            });

            document.getElementById('btn-mi-gps').addEventListener('click', function (e) {
                e.preventDefault();
                detectUserLocation();
            });

            // Close Alert button event listener
            var btnCerrarAlert = document.getElementById('btn-cerrar-alert');
            if (btnCerrarAlert) {
                btnCerrarAlert.addEventListener('click', function(e) {
                    e.preventDefault();
                    hideLocationAlert();
                });
            }

            // Fade instruction tip
            setTimeout(function () {
                var tip = document.getElementById('map-tip');
                if (tip) tip.style.opacity = '0';
            }, 9000);

            // Start location discovery on load
            detectUserLocation();

            // Fetch actual weekly stats from database/backend
            function updateBackendStats() {
                fetch('/api/stats')
                    .then(response => response.json())
                    .then(data => {
                        if (data) {
                            if (data.totalKg) document.getElementById('stat-totalKg').innerText = data.totalKg;
                            if (data.entregas) document.getElementById('stat-entregas').innerText = data.entregas;
                            if (data.puntos) document.getElementById('stat-puntos').innerText = data.puntos;
                        }
                    })
                    .catch(error => console.error("Error fetching stats:", error));
            }
            updateBackendStats();

            // Notation / Legend: poll backend for truck info
            function fetchCamionInfo() {
                fetch('/api/camion')
                    .then(resp => resp.json())
                    .then(data => {
                        if (!data) return;
                        var nameEl = document.getElementById('notation-name');
                        var descEl = document.getElementById('notation-desc');
                        var statusEl = document.getElementById('notation-status');
                        var updatedEl = document.getElementById('notation-updated');
                        var distanciaEl = document.getElementById('camion-distancia');
                        var direccionEl = document.getElementById('camion-direccion');

                        if (nameEl) nameEl.innerText = data.nombre || 'Camión Recolector';
                        if (descEl) descEl.innerText = (data.distancia ? data.distancia + ' · ' : '') + (data.direccion || 'Sin dirección');
                        if (distanciaEl && data.distancia) distanciaEl.innerText = data.distancia;
                        if (direccionEl && data.direccion) direccionEl.innerText = data.direccion;

                        var status = 'En ruta';
                        if (data.distancia && (data.distancia.toString().toLowerCase().includes('ruta completa') || data.distancia.toString().toLowerCase().includes('aquí') || data.distancia.toString().toLowerCase().includes('pasó'))) {
                            status = 'Finalizado';
                        } else if (data.distancia && data.distancia.toString().toLowerCase().includes('m')) {
                            status = 'En ruta';
                        }
                        if (statusEl) statusEl.innerText = status;

                        if (updatedEl) {
                            var now = new Date();
                            updatedEl.innerText = 'Actualizado ' + now.toLocaleTimeString();
                        }
                    })
                    .catch(err => console.warn('Error fetching /api/camion:', err));
            }

            fetchCamionInfo();
            setInterval(fetchCamionInfo, 4000);

            // Fetch environment news
            function fetchEnvNews() {
                fetch('/api/news')
                    .then(r => r.json())
                    .then(items => {
                        var list = document.getElementById('map-news-list');
                        if (!list) return;
                        list.innerHTML = '';
                        if (!items || items.length === 0) {
                            list.innerHTML = '<li class="text-on-surface-variant">No se encontraron noticias.</li>';
                            return;
                        }
                        items.slice(0,4).forEach(function(it) {
                            var li = document.createElement('li');
                            li.className = 'news-item';

                            var thumb = document.createElement('div');
                            thumb.className = 'news-thumb';
                            if (it.image) {
                                var img = document.createElement('img');
                                img.src = it.image;
                                img.alt = it.title || 'Imagen noticia';
                                thumb.appendChild(img);
                            } else {
                                thumb.innerHTML = '<div style="font-size:22px;">🌿</div>';
                            }

                            var content = document.createElement('div');
                            content.className = 'news-content';
                            var a = document.createElement('a');
                            a.href = it.link || '#';
                            a.target = '_blank';
                            a.rel = 'noopener noreferrer';
                            var title = it.title || '(sin título)';
                            if (title.length > 110) title = title.substring(0, 107) + '...';
                            a.innerText = title;

                            var meta = document.createElement('div');
                            meta.className = 'news-meta';
                            var src = (it.source || '').replace(/^https?:\/\//, '').replace(/\/.*/, '');
                            var date = it.pubDate ? new Date(it.pubDate).toLocaleString() : '';
                            var location = it.location || it.area || '';
                            var parts = [];
                            if (location) parts.push(location);
                            if (src) parts.push(src);
                            if (date) parts.push(date);
                            meta.innerText = parts.join(' · ');

                            content.appendChild(a);
                            content.appendChild(meta);

                            li.appendChild(thumb);
                            li.appendChild(content);
                            list.appendChild(li);
                        });
                    })
                    .catch(err => {
                        var list = document.getElementById('map-news-list');
                        if (list) list.innerHTML = '<li class="text-on-surface-variant">Error cargando noticias.</li>';
                        console.warn('Error fetching /api/news', err);
                    });
            }
            fetchEnvNews();
            setInterval(fetchEnvNews, 5 * 60 * 1000);
        });
    </script>
}
