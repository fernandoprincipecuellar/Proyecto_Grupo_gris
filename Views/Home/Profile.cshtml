@model Proyecto_Grupo_gris.Models.DashboardViewModel
@{
    ViewData["Title"] = "Mi Perfil";
}
<div class="container py-5">
    <div class="card shadow-sm p-4">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; font-size: 24px;">
                @Model.PerfilIniciales
            </div>
            <div>
                <h2 class="mb-0">@Model.NombreUsuario</h2>
                <p class="text-muted mb-0">@Model.CargoUsuario</p>
            </div>
        </div>
        <hr />
        <div class="row">
            <div class="col-md-6">
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Ciudad:</strong> @Model.Ciudad</p>
            </div>
        </div>
    </div>
</div>