@{
    ViewData["Title"] = "Perfil";
    var userPicture = User.FindFirst("Picture")?.Value ?? User.FindFirst("picture")?.Value ?? "https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y";
    var userName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Usuario";
    var userPhone = User.FindFirst("Phone")?.Value ?? "+34 612 345 678";
    var userCity = User.FindFirst("City")?.Value ?? "Madrid, España";
    var userBio = User.FindFirst("Bio")?.Value ?? "Eco-entusiasta y conductora comprometida con el planeta desde 2023 🌿";
}

<div class="profile-container py-4">
    <!-- Header Section -->
    <div class="profile-header-card">
        <div class="profile-cover">
            <img src="~/images/profile-cover.png" alt="Cover" class="profile-cover-img" />
            <div class="position-absolute top-0 end-0 m-3 d-flex gap-2" style="z-index: 10;">
                <a asp-action="EditProfile" class="btn btn-light btn-sm shadow-sm fw-bold border-0" style="border-radius: 10px; padding: 0.5rem 1rem;">
                    <i class="bi bi-pencil-square me-2"></i>Editar Perfil
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger btn-sm shadow-sm fw-bold border-0 px-3" style="border-radius: 10px; padding: 0.5rem 1rem;">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
        <div class="profile-avatar-wrapper">
            <img src="@userPicture" 
                 alt="Profile Picture" class="profile-avatar-img" />
            
            <div class="profile-header-info">
                <h1 class="profile-name">@userName</h1>
                <p class="profile-bio">@userBio</p>
            </div>


        </div>
        

    </div>

    <div class="profile-grid">
        <!-- Sidebar -->
        <div class="profile-sidebar">
            <div class="profile-side-card">
                <h5 class="profile-card-title"><i class="bi bi-info-circle-fill"></i> Información</h5>
                
                <div class="info-item">
                    <i class="bi bi-envelope-fill"></i>
                    <div>
                        <div class="small text-muted">Correo</div>
                        <div class="fw-medium">maria.g@email.com</div>
                    </div>
                </div>

                <div class="info-item">
                    <i class="bi bi-telephone-fill"></i>
                    <div>
                        <div class="small text-muted">Teléfono</div>
                        <div class="fw-medium">@userPhone</div>
                    </div>
                </div>

                <div class="info-item">
                    <i class="bi bi-geo-alt-fill"></i>
                    <div>
                        <div class="small text-muted">Ciudad</div>
                        <div class="fw-medium">@userCity</div>
                    </div>
                </div>

                <div class="info-item">
                    <i class="bi bi-calendar-check-fill"></i>
                    <div>
                        <div class="small text-muted">Se unió en</div>
                        <div class="fw-medium">Junio de 2023</div>
                    </div>
                </div>
            </div>

            <div class="profile-side-card">
                <h5 class="profile-card-title"><i class="bi bi-award-fill"></i> Logros</h5>
                
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-3 text-warning">
                        <i class="bi bi-trophy-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold">Eco-Conductor del Mes</div>
                        <div class="small text-muted">Menor huella de carbono</div>
                    </div>
                </div>

                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-2 rounded-3 me-3 text-success">
                        <i class="bi bi-leaf-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold">100 Viajes Verdes</div>
                        <div class="small text-muted">Completados este año</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="profile-main-content">


            <!-- Recent Activity -->
            <div class="profile-side-card">
                <h5 class="profile-card-title"><i class="bi bi-clock-history"></i> Actividad Reciente</h5>
                
                <div class="activity-item">
                    <div class="activity-icon">
                        <i class="bi bi-recycle"></i>
                    </div>
                    <div class="activity-content">
                        <h6>Reciclaje de Plástico Completado</h6>
                        <p>Has reciclado 2.5kg de envases PET en el Punto Verde Centro.</p>
                        <small class="text-muted">Hace 2 horas</small>
                    </div>
                </div>

                <div class="activity-item">
                    <div class="activity-icon">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <div class="activity-content">
                        <h6>Nuevo Punto de Reciclaje Visitado</h6>
                        <p>Has registrado tu primera visita al Punto de Reciclaje "EcoPark Norte".</p>
                        <small class="text-muted">Ayer a las 18:30</small>
                    </div>
                </div>

                <div class="activity-item">
                    <div class="activity-icon">
                        <i class="bi bi-star-fill text-warning"></i>
                    </div>
                    <div class="activity-content">
                        <h6>Reseña Publicada</h6>
                        <p>Calificaste con 5 estrellas el servicio de recolección selectiva.</p>
                        <small class="text-muted">Hace 3 días</small>
                    </div>
                </div>

                <div class="text-center mt-3">
                    <button class="btn btn-link text-success text-decoration-none fw-bold">Ver toda la actividad</button>
                </div>
            </div>
        </div>
    </div>
</div>
