@model Proyecto_Grupo_gris.Models.DashboardViewModel

@{
    ViewData["Title"] = "Perfil";
}

<div class="profile-page container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-8">
            <section class="profile-page-card p-5 rounded-5 shadow-sm bg-white">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-5">
                    <div>
                        <p class="dashboard-section-label mb-2">Perfil</p>
                        <h1 class="profile-page-title">Tu información</h1>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm profile-settings-btn">⚙</button>
                </div>

                <div class="text-center mb-5">
            <div class="profile-avatar mb-3">@Model.PerfilIniciales</div>
            <h3 class="h4 mb-1">@Model.NombreUsuario</h3>
            <p class="text-muted mb-0">@Model.CargoUsuario</p>
        </div>

        <div class="profile-info-list mb-5">
            <div class="profile-info-item d-flex align-items-center mb-3">
                <span class="profile-info-icon">✉️</span>
                <div>
                    <div class="profile-info-label">Correo</div>
                    <div class="profile-info-value">@Model.Email</div>
                </div>
            </div>
            <div class="profile-info-item d-flex align-items-center mb-3">
                <span class="profile-info-icon">📞</span>
                <div>
                    <div class="profile-info-label">Teléfono</div>
                    <div class="profile-info-value">@Model.Telefono</div>
                </div>
            </div>
            <div class="profile-info-item d-flex align-items-center">
                <span class="profile-info-icon">📍</span>
                <div>
                    <div class="profile-info-label">Ciudad</div>
                    <div class="profile-info-value">@Model.Ciudad</div>
                </div>
            </div>
        </div>

        <div class="profile-achievements">
            <h2 class="h5 mb-3">Logros Recientes</h2>
            <div class="achievement-item p-4 mb-3 rounded-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="achievement-icon">🏆</div>
                    <div>
                        <strong>@Model.Logro1Titulo</strong>
                        <p class="mb-0 text-muted">@Model.Logro1Descripcion</p>
                    </div>
                </div>
            </div>
            <div class="achievement-item p-4 rounded-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="achievement-icon">🍃</div>
                    <div>
                        <strong>@Model.Logro2Titulo</strong>
                        <p class="mb-0 text-muted">@Model.Logro2Descripcion</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
</div>
