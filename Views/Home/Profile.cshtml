@{
    ViewData["Title"] = "Perfil";
}

<div class="profile-page py-4">
    <div class="mx-auto" style="max-width: 450px;">
        
        <!-- Header Perfil -->
        <div class="text-center mb-4 position-relative">
            <div class="position-relative d-inline-block">
                <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-1.2.1&auto=format&fit=crop&w=256&q=80" 
                     alt="Profile Picture" 
                     class="rounded-circle shadow-sm" 
                     style="width: 130px; height: 130px; object-fit: cover; border: 5px solid #bbf7d0;">
                
                <div class="position-absolute d-flex align-items-center justify-content-center bg-success text-white rounded-circle shadow"
                     style="bottom: 5px; right: 5px; width: 36px; height: 36px; cursor: pointer;">
                    <i class="bi bi-camera-fill"></i>
                </div>
            </div>
            
            <h3 class="mt-3 mb-1 fw-bold" style="color: #0f2d1d;">María González</h3>
            <p class="text-secondary" style="font-size: 0.95rem;">Eco-conductora desde 2023</p>
        </div>

        <!-- Información Personal -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; border: 1px solid #f3f4f6 !important;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4" style="color: #111827;">Información Personal</h5>
                
                <div class="d-flex align-items-center mb-4">
                    <i class="bi bi-envelope-fill fs-5 me-3" style="color: #15803d;"></i>
                    <div class="text-secondary" style="width: 80px; font-size: 0.95rem;">Correo</div>
                    <div class="fw-medium ms-auto text-dark">maria.g@email.com</div>
                </div>
                
                <div class="d-flex align-items-center mb-4">
                    <i class="bi bi-telephone-fill fs-5 me-3" style="color: #15803d;"></i>
                    <div class="text-secondary" style="width: 80px; font-size: 0.95rem;">Teléfono</div>
                    <div class="fw-medium ms-auto text-dark">+34 612 345 678</div>
                </div>
                
                <div class="d-flex align-items-center">
                    <i class="bi bi-geo-alt-fill fs-5 me-3" style="color: #15803d;"></i>
                    <div class="text-secondary" style="width: 80px; font-size: 0.95rem;">Ciudad</div>
                    <div class="fw-medium ms-auto text-dark">Madrid, España</div>
                </div>
            </div>
        </div>

        <!-- Logros Recientes -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px; border: 1px solid #f3f4f6 !important;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4" style="color: #111827;">Logros Recientes</h5>
                
                <div class="d-flex align-items-center mb-4">
                    <div class="d-flex align-items-center justify-content-center rounded-3 me-3" style="width: 50px; height: 50px; background-color: #fef08a;">
                        <i class="bi bi-trophy-fill fs-4" style="color: #a16207;"></i>
                    </div>
                    <div>
                        <div class="fw-medium text-dark" style="font-size: 1.05rem;">Eco-Conductor del Mes</div>
                        <div class="text-secondary" style="font-size: 0.85rem;">Menor huella de carbono</div>
                    </div>
                </div>
                
                <div class="d-flex align-items-center">
                    <div class="d-flex align-items-center justify-content-center rounded-3 me-3" style="width: 50px; height: 50px; background-color: #dcfce7;">
                        <i class="bi bi-leaf-fill fs-4" style="color: #15803d;"></i>
                    </div>
                    <div>
                        <div class="fw-medium text-dark" style="font-size: 1.05rem;">100 Viajes Verdes</div>
                        <div class="text-secondary" style="font-size: 0.85rem;">Completados este año</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Botón de Cerrar Sesión (Logout) -->
        <form asp-controller="Account" asp-action="Logout" method="post" class="mt-4 text-center">
            <button type="submit" class="btn btn-outline-danger px-4 rounded-pill fw-bold" style="border-width: 2px;">
                <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
            </button>
        </form>

    </div>
</div>
