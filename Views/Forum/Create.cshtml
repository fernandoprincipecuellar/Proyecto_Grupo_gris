@model Proyecto_Grupo_gris.Models.ForumPost

@{
    ViewData["Title"] = "Nuevo Reporte";
}

<div class="py-8 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
    <div class="max-w-5xl mx-auto">
        <div class="glass-card rounded-3xl overflow-hidden">
            <div class="flex flex-col lg:flex-row">
                <!-- Lateral Informativo -->
                <div class="lg:w-5/12 hidden lg:flex flex-col justify-between p-8 text-white relative" style="background: linear-gradient(135deg, #006c50 0%, #001915 100%);">
                    <div class="relative z-10">
                        <a asp-action="Index" class="inline-flex items-center gap-2 text-white/75 hover:text-white transition-colors mb-8 font-label-md text-label-md">
                            <span class="material-symbols-outlined text-lg">arrow_back</span> Volver al foro
                        </a>
                        <h2 class="font-display-lg text-display-lg-mobile mb-4">Reporta un Incidente</h2>
                        <p class="font-body-lg text-body-lg opacity-75 mb-8">Tu participacion es fundamental para cuidar nuestro ecosistema. Envía tu reporte y las autoridades correspondientes podran tomar accion.</p>
                        
                        <div class="glass-card bg-white/10 p-6 rounded-2xl mb-4">
                            <h5 class="font-headline-md text-headline-md mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined">shield</span> Consejos para un buen reporte
                            </h5>
                            <ul class="space-y-4">
                                <li class="flex gap-3 items-start">
                                    <div class="bg-white/20 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold shrink-0">1</div>
                                    <span>Sé especifico en la descripcion del problema.</span>
                                </li>
                                <li class="flex gap-3 items-start">
                                    <div class="bg-white/20 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold shrink-0">2</div>
                                    <span>Asegurate de que la foto sea clara y nitida.</span>
                                </li>
                                <li class="flex gap-3 items-start">
                                    <div class="bg-white/20 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold shrink-0">3</div>
                                    <span>Indica el nivel de urgencia real.</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="absolute bottom-0 right-0 opacity-10 pointer-events-none">
                        <span class="material-symbols-outlined" style="font-size: 15rem; transform: rotate(15deg); display: block;">eco</span>
                    </div>
                </div>

                <!-- Formulario -->
                <div class="lg:w-7/12 p-6 md:p-8">
                    <div class="lg:hidden mb-4">
                        <a asp-action="Index" class="text-secondary flex items-center gap-2 font-label-md text-label-md">
                            <span class="material-symbols-outlined text-lg">arrow_back</span> Volver al foro
                        </a>
                        <h2 class="font-headline-lg text-headline-lg-mobile mt-3 font-bold">Nuevo reporte</h2>
                    </div>

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div class="space-y-6">
                            <!-- Tipo de Reporte -->
                            <div>
                                <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Que esta sucediendo?</label>
                                <select asp-for="ReportType" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all font-body-md">
                                    <option value="" selected disabled>Seleccionar categoria</option>
                                    <option value="Contaminación de agua">Contaminacion de agua</option>
                                    <option value="Botadero ilegal">Botadero ilegal</option>
                                    <option value="Calidad del aire">Calidad del aire</option>
                                    <option value="Tala de árboles">Tala de arboles</option>
                                    <option value="Maltrato animal/fauna">Maltrato animal o fauna silvestre</option>
                                    <option value="Otro">Otro incidente ambiental</option>
                                </select>
                                <span asp-validation-for="ReportType" class="text-error text-xs mt-1 block"></span>
                            </div>

                            <!-- Descripcion -->
                            <div>
                                <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Descripcion detallada</label>
                                <textarea asp-for="Description" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border border-outline-variant focus:border-secondary focus:ring-2 focus:ring-secondary/20 outline-none transition-all font-body-md" rows="4" placeholder="Cuentanos mas detalles sobre el incidente..."></textarea>
                                <span asp-validation-for="Description" class="text-error text-xs mt-1 block"></span>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <!-- Imagen -->
                                <div>
                                    <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Evidencia visual</label>
                                    <div class="border-2 border-dashed border-outline-variant rounded-2xl p-6 text-center cursor-pointer hover:border-secondary hover:bg-secondary/5 transition-all" onclick="document.getElementById('imageUpload').click();">
                                        <input type="file" id="imageUpload" name="imageFile" hidden accept="image/*" onchange="previewImage(this)" />
                                        <div id="uploadPlaceholder">
                                            <span class="material-symbols-outlined text-secondary text-4xl mb-2 block">cloud_upload</span>
                                            <p class="font-bold text-on-surface mb-1">Adjuntar foto</p>
                                            <p class="text-sm text-on-surface-variant">Haz clic para subir</p>
                                        </div>
                                        <img id="imagePreview" src="#" alt="Preview" class="rounded-xl max-h-[180px] mx-auto d-none" />
                                    </div>
                                </div>

                                <!-- Ubicacion -->
                                <div>
                                    <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Ubicacion</label>
                                    <div class="rounded-2xl overflow-hidden border border-outline-variant">
                                        <div class="h-20 bg-surface-container-low" style="background-image: linear-gradient(45deg, #e4e9e8 25%, transparent 25%, transparent 50%, #e4e9e8 50%, #e4e9e8 75%, transparent 75%, transparent); background-size: 20px 20px;"></div>
                                        <div class="p-3 bg-surface-container-low">
                                            <div class="flex items-center gap-2 mb-1">
                                                <span class="material-symbols-outlined text-error text-sm">location_on</span>
                                                <span class="font-bold text-sm">Ubicacion detectada</span>
                                            </div>
                                            <p class="text-on-surface-variant text-xs m-0">Calle Principal 123, Madrid</p>
                                            <input type="hidden" asp-for="Location" value="Calle Principal 123, Madrid" />
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Urgencia -->
                            <div>
                                <label class="block font-label-md text-label-md text-on-surface uppercase tracking-wider mb-2">Nivel de prioridad</label>
                                <div class="flex gap-4">
                                    <label class="flex-1 cursor-pointer">
                                        <input type="radio" asp-for="Urgency" value="Baja" id="urg-low" class="peer hidden" />
                                        <div class="peer-checked:border-secondary peer-checked:bg-secondary/10 peer-checked:text-secondary border-2 border-outline-variant rounded-xl p-3 text-center font-bold transition-all">
                                            Baja
                                        </div>
                                    </label>
                                    <label class="flex-1 cursor-pointer">
                                        <input type="radio" asp-for="Urgency" value="Media" id="urg-med" class="peer hidden" checked />
                                        <div class="peer-checked:border-secondary peer-checked:bg-secondary/10 peer-checked:text-secondary border-2 border-outline-variant rounded-xl p-3 text-center font-bold transition-all">
                                            Media
                                        </div>
                                    </label>
                                    <label class="flex-1 cursor-pointer">
                                        <input type="radio" asp-for="Urgency" value="Alta" id="urg-high" class="peer hidden" />
                                        <div class="peer-checked:border-error peer-checked:bg-error/10 peer-checked:text-error border-2 border-outline-variant rounded-xl p-3 text-center font-bold transition-all">
                                            Alta
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <!-- Boton de Envio -->
                            <button type="submit" class="w-full py-4 bg-secondary text-white rounded-xl font-label-md text-label-md font-bold hover:bg-on-secondary-fixed-variant transition-all flex items-center justify-center gap-2 active:scale-[0.98] shadow-lg shadow-secondary/20">
                                Publicar Reporte
                                <span class="material-symbols-outlined text-lg">send</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    const preview = document.getElementById('imagePreview');
                    const placeholder = document.getElementById('uploadPlaceholder');
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    placeholder.classList.add('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
