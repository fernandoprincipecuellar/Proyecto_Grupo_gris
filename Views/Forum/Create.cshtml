@model Proyecto_Grupo_gris.Models.ForumPost

@{
    ViewData["Title"] = "Nuevo Reporte";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-11">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="row g-0">
                    <!-- Lateral Informativo (Lado Izquierdo) -->
                    <div class="col-lg-5 d-none d-lg-flex flex-column justify-content-between p-5 text-white position-relative" style="background: linear-gradient(135deg, #166534 0%, #064e3b 100%);">
                        <div class="position-relative z-index-2">
                            <a asp-action="Index" class="btn btn-link text-white text-decoration-none p-0 mb-5 d-inline-flex align-items-center gap-2 opacity-75 hover-opacity-100">
                                <i class="bi bi-arrow-left"></i> Volver al foro
                            </a>
                            <h2 class="display-5 fw-bold mb-4">Reporta un Incidente</h2>
                            <p class="fs-5 opacity-75 mb-5">Tu participación es fundamental para cuidar nuestro ecosistema. Envía tu reporte y las autoridades correspondientes podrán tomar acción.</p>
                            
                            <div class="glass-panel p-4 rounded-4 mb-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-shield-check me-2"></i>Consejos para un buen reporte</h5>
                                <ul class="list-unstyled m-0">
                                    <li class="mb-3 d-flex gap-3 align-items-start">
                                        <div class="bg-white bg-opacity-20 rounded-circle p-1 px-2 small">1</div>
                                        <span>Sé específico en la descripción del problema.</span>
                                    </li>
                                    <li class="mb-3 d-flex gap-3 align-items-start">
                                        <div class="bg-white bg-opacity-20 rounded-circle p-1 px-2 small">2</div>
                                        <span>Asegúrate de que la foto sea clara y nítida.</span>
                                    </li>
                                    <li class="d-flex gap-3 align-items-start">
                                        <div class="bg-white bg-opacity-20 rounded-circle p-1 px-2 small">3</div>
                                        <span>Indica el nivel de urgencia real.</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        
                        <div class="position-relative z-index-2 mt-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-white rounded-circle" style="width: 10px; height: 10px;"></div>
                                <div class="bg-white bg-opacity-25 rounded-circle" style="width: 10px; height: 10px;"></div>
                                <div class="bg-white bg-opacity-25 rounded-circle" style="width: 10px; height: 10px;"></div>
                            </div>
                        </div>

                        <!-- Decoración de fondo -->
                        <div class="position-absolute bottom-0 end-0 p-4 opacity-10" style="pointer-events: none;">
                            <i class="bi bi-recycle" style="font-size: 15rem; transform: rotate(15deg); display: block;"></i>
                        </div>
                    </div>

                    <!-- Formulario (Lado Derecho) -->
                    <div class="col-lg-7 p-4 p-md-5 bg-white">
                        <div class="d-lg-none mb-4">
                            <a asp-action="Index" class="text-success text-decoration-none d-flex align-items-center gap-2">
                                <i class="bi bi-arrow-left"></i> Volver al foro
                            </a>
                            <h2 class="fw-bold mt-3">Nuevo reporte</h2>
                        </div>

                        <form asp-action="Create" method="post" enctype="multipart/form-data">
                            <div class="row g-4">
                                <!-- Tipo de Reporte -->
                                <div class="col-md-12">
                                    <label class="form-label fw-bold text-dark">¿Qué está sucediendo?</label>
                                    <select asp-for="ReportType" class="form-select modern-input py-3">
                                        <option value="" disabled selected>Seleccionar categoría</option>
                                        <option value="Contaminación de agua">Contaminación de agua</option>
                                        <option value="Botadero ilegal">Botadero ilegal</option>
                                        <option value="Calidad del aire">Calidad del aire</option>
                                        <option value="Tala de árboles">Tala de árboles</option>
                                        <option value="Maltrato animal/fauna">Maltrato animal o fauna silvestre</option>
                                        <option value="Otro">Otro incidente ambiental</option>
                                    </select>
                                    <span asp-validation-for="ReportType" class="text-danger small"></span>
                                </div>

                                <!-- Descripción -->
                                <div class="col-md-12">
                                    <label class="form-label fw-bold text-dark">Descripción detallada</label>
                                    <textarea asp-for="Description" class="form-control modern-input" rows="4" placeholder="Cuéntanos más detalles sobre el incidente..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger small"></span>
                                </div>

                                <!-- Imagen -->
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Evidencia visual</label>
                                    <div class="modern-upload-card" onclick="document.getElementById('imageUpload').click();">
                                        <input type="file" id="imageUpload" name="imageFile" hidden accept="image/*" onchange="previewImage(this)" />
                                        <div id="uploadPlaceholder">
                                            <i class="bi bi-cloud-arrow-up display-5 text-success mb-3"></i>
                                            <p class="mb-1 fw-bold">Adjuntar foto</p>
                                            <p class="small text-muted m-0">Haz clic para subir</p>
                                        </div>
                                        <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded-3 d-none" style="max-height: 180px;" />
                                    </div>
                                </div>

                                <!-- Ubicación -->
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-dark">Ubicación</label>
                                    <div class="modern-location-card">
                                        <div class="map-stripes"></div>
                                        <div class="p-3 bg-light border-top">
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <i class="bi bi-geo-alt-fill text-danger"></i>
                                                <span class="fw-bold small">Ubicación detectada</span>
                                            </div>
                                            <p class="text-muted smaller mb-0">Calle Principal 123, Madrid</p>
                                            <input type="hidden" asp-for="Location" value="Calle Principal 123, Madrid" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Urgencia -->
                                <div class="col-md-12">
                                    <label class="form-label fw-bold text-dark">Nivel de prioridad</label>
                                    <div class="modern-urgency-group">
                                        <input type="radio" asp-for="Urgency" value="Baja" id="urg-low" class="btn-check" />
                                        <label class="btn btn-modern-urgency" for="urg-low">Baja</label>

                                        <input type="radio" asp-for="Urgency" value="Media" id="urg-med" class="btn-check" checked />
                                        <label class="btn btn-modern-urgency" for="urg-med">Media</label>

                                        <input type="radio" asp-for="Urgency" value="Alta" id="urg-high" class="btn-check" />
                                        <label class="btn btn-modern-urgency" for="urg-high">Alta</label>
                                    </div>
                                </div>

                                <!-- Botón de Envío -->
                                <div class="col-md-12 pt-3">
                                    <button type="submit" class="btn btn-success btn-lg w-100 py-3 rounded-3 fw-bold shadow-sm hover-up">
                                        Publicar Reporte <i class="bi bi-send-fill ms-2"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    const preview = document.getElementById('imagePreview');
                    const placeholder = document.getElementById('uploadPlaceholder');
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    placeholder.classList.add('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

<style>
    .glass-panel {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .z-index-2 {
        z-index: 2;
    }
    
    .modern-input {
        border: 2px solid #f3f4f6;
        border-radius: 12px;
        padding-left: 1.25rem;
        transition: all 0.2s;
    }
    
    .modern-input:focus {
        border-color: #166534;
        box-shadow: 0 0 0 4px rgba(22, 101, 52, 0.1);
    }
    
    .modern-upload-card {
        border: 2px dashed #e5e7eb;
        border-radius: 16px;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        background: #f9fafb;
        transition: all 0.2s;
        height: 140px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
    
    .modern-upload-card:hover {
        border-color: #166534;
        background: #f0fdf4;
    }
    
    .modern-location-card {
        border: 2px solid #f3f4f6;
        border-radius: 16px;
        overflow: hidden;
        height: 140px;
        display: flex;
        flex-direction: column;
    }
    
    .map-stripes {
        flex: 1;
        background: #eef2ff;
        background-image: linear-gradient(45deg, #e0e7ff 25%, transparent 25%, transparent 50%, #e0e7ff 50%, #e0e7ff 75%, transparent 75%, transparent);
        background-size: 20px 20px;
    }
    
    .modern-urgency-group {
        display: flex;
        gap: 1rem;
    }
    
    .btn-modern-urgency {
        flex: 1;
        border: 2px solid #f3f4f6;
        border-radius: 12px;
        padding: 0.75rem;
        font-weight: 700;
        background: white;
        color: #6b7280;
    }
    
    .btn-check:checked + .btn-modern-urgency {
        border-color: #166534;
        background: #f0fdf4;
        color: #166534;
    }
    
    .hover-up {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .hover-up:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(22, 101, 52, 0.25) !important;
    }
    
    .hover-opacity-100:hover {
        opacity: 1 !important;
    }
    
    .smaller { font-size: 0.75rem; }
</style>
