@using System.Security.Claims
@model IEnumerable<Proyecto_Grupo_gris.Models.ForumPost>

@{
    ViewData["Title"] = "Foro Ambiental";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="forum-container">
    <div class="forum-header">
        <div>
            <h1 class="display-5 fw-bold text-success mb-1">Foro Comunitario</h1>
            <p class="text-muted">Reportes y denuncias ambientales de la comunidad.</p>
        </div>
        <div class="d-none d-md-block">
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 py-2">
                <i class="bi bi-plus-lg me-2"></i>Nuevo reporte
            </a>
        </div>
    </div>

    <div class="forum-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var post in Model)
            {
                <div class="forum-card">
                    <div class="forum-card-img-wrapper">
                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <img src="@post.ImageUrl" alt="@post.ReportType" class="forum-card-img" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100 bg-secondary-subtle">
                                <i class="bi bi-image fs-1 text-muted"></i>
                            </div>
                        }
                    </div>
                    <div class="forum-card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge @(post.Urgency == "Alta" ? "bg-danger" : post.Urgency == "Media" ? "bg-warning text-dark" : "bg-info text-dark")">
                                @post.Urgency
                            </span>
                            
                            @if (post.UserId == currentUserId && !string.IsNullOrEmpty(currentUserId))
                            {
                                <form asp-action="Delete" method="post" onsubmit="return confirm('¿Estás seguro de que quieres eliminar este reporte?');">
                                    <input type="hidden" name="id" value="@post.Id" />
                                    <button type="submit" class="btn btn-link text-danger p-0 fs-5 lh-1" title="Eliminar reporte">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            }
                        </div>
                        
                        <p class="forum-card-text">@post.Description</p>
                        
                        <div class="d-flex align-items-center justify-content-between mt-auto pt-2 border-top">
                            <div class="forum-card-location m-0">
                                <i class="bi bi-geo-alt-fill text-success"></i> @post.Location
                            </div>
                            <small class="text-muted">@post.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</small>
                        </div>
                    </div>
                    <div class="forum-card-footer">
                        <div class="forum-footer-item">
                            <i class="bi bi-chat-dots"></i> @post.CommentsCount
                        </div>
                        <div class="forum-footer-item">
                            <i class="bi bi-heart-fill"></i> @post.LikesCount
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="bg-white rounded-4 p-5 shadow-sm border border-dashed">
                    <i class="bi bi-chat-square-text display-1 text-success opacity-25 mb-4"></i>
                    <h3 class="fw-bold">No hay reportes aún</h3>
                    <p class="text-muted">Sé el primero en compartir un incidente ambiental en tu comunidad.</p>
                    <a asp-action="Create" class="btn btn-success rounded-pill px-4 mt-3">Crear primer reporte</a>
                </div>
            </div>
        }
    </div>
</div>

<a asp-action="Create" class="forum-floating-btn d-md-none">
    <i class="bi bi-plus-lg"></i> Nuevo reporte
</a>

<a asp-action="Create" class="forum-floating-btn d-none d-md-flex">
    <i class="bi bi-plus-lg"></i> Nuevo reporte
</a>
