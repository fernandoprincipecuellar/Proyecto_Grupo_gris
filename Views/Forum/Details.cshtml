@model Proyecto_Grupo_gris.Models.ForumPost

@{
    ViewData["Title"] = "Detalles del Reporte";
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-success text-decoration-none fw-bold">Foro</a></li>
            <li class="breadcrumb-item active" aria-current="page">Detalles del Reporte</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="details-img-container">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.ReportType" class="w-100 h-100 object-fit-cover" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                            <i class="bi bi-image fs-1 text-muted"></i>
                        </div>
                    }
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                        <span class="badge @(Model.Urgency == "Alta" ? "bg-danger" : Model.Urgency == "Media" ? "bg-warning text-dark" : "bg-info text-dark") fs-6 px-3 py-2 rounded-pill">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Urgencia: @Model.Urgency
                        </span>
                        <span class="badge bg-success-subtle text-success fs-6 px-3 py-2 rounded-pill">
                            <i class="bi bi-tag-fill me-1"></i> @Model.ReportType
                        </span>
                    </div>

                    <h1 class="display-6 fw-bold mb-4">@Model.ReportType</h1>
                    
                    <div class="mb-5">
                        <h5 class="fw-bold text-muted text-uppercase small letter-spacing-1 mb-3">Descripción</h5>
                        <p class="fs-5 lh-base">@Model.Description</p>
                    </div>

                    <div class="row g-4 border-top pt-4">
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-success-subtle p-3 rounded-4 text-success">
                                    <i class="bi bi-geo-alt-fill fs-3"></i>
                                </div>
                                <div>
                                    <p class="text-muted small mb-0 fw-bold text-uppercase">Ubicación</p>
                                    <p class="mb-0 fw-medium">@Model.Location</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-info-subtle p-3 rounded-4 text-info">
                                    <i class="bi bi-calendar-event fs-3"></i>
                                </div>
                                <div>
                                    <p class="text-muted small mb-0 fw-bold text-uppercase">Fecha del Reporte</p>
                                    <p class="mb-0 fw-medium">@Model.CreatedAt.ToLocalTime().ToString("dd 'de' MMMM, yyyy")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
                <h5 class="fw-bold mb-4">Interacción</h5>
                <div class="d-grid gap-3">
                    <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-3">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-heart-fill text-danger"></i>
                            <span class="fw-bold">@Model.LikesCount Likes</span>
                        </div>
                        <button class="btn btn-outline-danger btn-sm rounded-pill px-3">Me gusta</button>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-3">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-chat-dots-fill text-primary"></i>
                            <span class="fw-bold">@Model.CommentsCount Comentarios</span>
                        </div>
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3">Comentar</button>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="p-4 bg-success text-white">
                    <h5 class="fw-bold mb-0">Acciones Rápidas</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a asp-action="Index" class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-3">
                        <i class="bi bi-arrow-left text-success fs-5"></i> Volver al Foro
                    </a>
                    <a href="#" class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-3">
                        <i class="bi bi-share text-success fs-5"></i> Compartir Reporte
                    </a>
                    <a href="#" class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-3 text-danger">
                        <i class="bi bi-flag fs-5"></i> Reportar Inconveniente
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .details-img-container {
        height: 450px;
        background: #f8f9fa;
    }
    .letter-spacing-1 {
        letter-spacing: 1px;
    }
    .object-fit-cover {
        object-fit: cover;
    }
</style>
