@model Proyecto_Grupo_gris.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="login-page-wrapper d-flex align-items-center justify-content-center min-vh-100">
    <div class="login-inner text-center">
        <div class="login-brand mb-4">
            <h1 class="app-brand">EcoRuta</h1>
            <p class="app-subtitle">Reciclaje inteligente</p>
        </div>

        <div class="login-card p-4 shadow-sm">
            <h2 class="login-card-title mb-4">Iniciar Sesión</h2>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3 text-start">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="Correo electrónico" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4 text-start">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" placeholder="Contraseña" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <input asp-for="ReturnUrl" type="hidden" />
                <button type="submit" class="btn btn-eco w-100 py-2">Ingresar</button>
            </form>

            <p class="login-register-text mt-4">¿No tienes cuenta? <a asp-area="Identity" asp-page="/Account/Register">Regístrate</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
