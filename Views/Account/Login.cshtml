@model Proyecto_Grupo_gris.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout";
}

<div class="auth-split-wrapper">
    <!-- Left: Form Side -->
    <div class="auth-form-side">
        <div class="auth-form-inner">
            <!-- Brand -->
            <div class="auth-brand">
                <span class="auth-brand-icon"><i class="bi bi-recycle"></i></span>
                <span class="auth-brand-name">EcoRuta</span>
            </div>

            <h1 class="auth-title">Bienvenidos</h1>

            <!-- Login Form -->
            <form asp-action="Login" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="auth-field-group">
                    <label asp-for="Email" class="auth-field-label"></label>
                    <input asp-for="Email" class="auth-field-input" placeholder="tu@correo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="auth-field-group">
                    <label asp-for="Password" class="auth-field-label"></label>
                    <input asp-for="Password" class="auth-field-input" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="auth-options">
                    <label class="auth-checkbox">
                        <input type="checkbox" name="RememberMe" />
                        <span>Recordarme</span>
                    </label>
                    <a href="#" class="auth-forgot-link">Olvidé mi contraseña</a>
                </div>

                <input asp-for="ReturnUrl" type="hidden" />
                <button type="submit" class="btn auth-btn-submit w-100">Ingresar</button>
            </form>

            <p class="auth-switch-text">
                ¿No tienes cuenta?
                <a asp-controller="Account" asp-action="Register">Regístrate</a>
            </p>
        </div>
    </div>

    <!-- Right: Illustration Side -->
    <div class="auth-illustration-side">
        <img src="~/images/eco-illustration.png" alt="Eco illustration" class="auth-illustration-img" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
