@model Proyecto_Grupo_gris.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesion";
    Layout = "_Layout";
}

<div class="auth-split-wrapper">
    <!-- Left: Form Side -->
    <div class="auth-form-side">
        <div class="auth-form-inner">
            <!-- Brand -->
            <div class="auth-brand">
                <span class="material-symbols-outlined auth-brand-icon text-2xl">eco</span>
                <span class="auth-brand-name">EcoRuta</span>
            </div>

            <h1 class="auth-title">
                @if (!string.IsNullOrEmpty(ViewBag.UserName))
                {
                    <span>Hola de nuevo, @ViewBag.UserName!</span>
                }
                else
                {
                    <span>Bienvenidos</span>
                }
            </h1>

            <!-- Google Login -->
            <form asp-controller="Account" asp-action="ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mb-3">
                <button type="submit" name="provider" value="Google" class="auth-btn-google w-100">
                    <img src="https://developers.google.com/identity/images/g-logo.png" width="20" alt="Google">
                    Ingresar con Google
                </button>
            </form>

            <!-- Divider -->
            <div class="auth-divider">
                <span>O INGRESA CON TU CORREO</span>
            </div>

            <!-- Login Form -->
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-error mb-3 text-sm"></div>

                <div class="auth-field-group">
                    <label asp-for="Email" class="auth-field-label"></label>
                    <input asp-for="Email" class="auth-field-input" placeholder="tu@correo.com" />
                    <span asp-validation-for="Email" class="text-error text-xs"></span>
                </div>

                <div class="auth-field-group">
                    <label asp-for="Password" class="auth-field-label"></label>
                    <input asp-for="Password" class="auth-field-input" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-error text-xs"></span>
                </div>

                <div class="auth-options">
                    <label class="auth-checkbox">
                        <input type="checkbox" name="RememberMe" />
                        <span>Recordarme</span>
                    </label>
                    <a href="#" class="auth-forgot-link">Olvide mi contrasena</a>
                </div>

                <input asp-for="ReturnUrl" type="hidden" />
                <button type="submit" class="auth-btn-submit">Ingresar</button>
            </form>

            <p class="auth-switch-text">
                No tienes cuenta?
                <a asp-controller="Account" asp-action="Register">Registrate</a>
            </p>
        </div>
    </div>

    <!-- Right: Illustration Side -->
    <div class="auth-illustration-side">
        <img src="~/images/eco-illustration.png" alt="Eco illustration" class="auth-illustration-img" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
