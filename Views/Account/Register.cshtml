@model Proyecto_Grupo_gris.Models.RegisterViewModel

@{
    ViewData["Title"] = "Registro";
}

<div class="container text-center mt-5">
    <h1 style="color:#2f6f4f;">EcoRuta</h1>
    <p>Reciclaje inteligente</p>

    <div class="card mx-auto p-4" style="width:350px; border-radius:15px;">
        <h2 class="text-center">Registrarse</h2>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group mt-3">
                <label asp-for="Nombre"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="row mt-3">
                <div class="col">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" />
                </div>
                <div class="col">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                </div>
            </div>

            <span asp-validation-summary="All" class="text-danger"></span>

            <button type="submit" class="btn btn-success w-100 mt-4">
                Registrarse
            </button>
        </form>

        <hr />

        <form asp-controller="Account" asp-action="ExternalLogin" method="post">
            <button type="submit" name="provider" value="Google" class="btn btn-light border w-100">
                <img src="https://developers.google.com/identity/images/g-logo.png" width="20">
             Registrarse con Google
            </button>
        </form>do

        <div class="text-center mt-3">
            ¿Ya tienes cuenta? 
            <a asp-action="Login">Inicia sesión</a>
        </div>

    </div>
</div>