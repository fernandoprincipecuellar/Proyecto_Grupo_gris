@model Proyecto_Grupo_gris.Models.RegisterViewModel

@{
    ViewData["Title"] = "Registro";
    Layout = "_Layout";
}

<div class="auth-split-wrapper">
    <!-- Left: Form Side -->
    <div class="auth-form-side">
        <div class="auth-form-inner">
            <!-- Brand -->
            <div class="auth-brand">
                <span class="auth-brand-icon"><i class="bi bi-recycle"></i></span>
                <span class="auth-brand-name">EcoRuta</span>
            </div>

            <h1 class="auth-title">Crear Cuenta</h1>

            <!-- Google Register -->
            <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="mb-3">
                <button type="submit" name="provider" value="Google" class="btn auth-btn-google w-100">
                    <img src="https://developers.google.com/identity/images/g-logo.png" width="20" alt="Google">
                    Registrarse con Google
                </button>
            </form>

            <!-- Divider -->
            <div class="auth-divider">
                <span>O REGÍSTRATE CON TU CORREO</span>
            </div>

            <!-- Register Form -->
            <form asp-action="Register" method="post" class="auth-form">
                @Html.AntiForgeryToken()

                <div class="auth-field-group">
                    <label asp-for="Nombre" class="auth-field-label"></label>
                    <input asp-for="Nombre" class="auth-field-input" placeholder="Tu nombre completo" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>

                <div class="auth-field-group">
                    <label asp-for="Email" class="auth-field-label"></label>
                    <input asp-for="Email" class="auth-field-input" placeholder="tu@correo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="auth-field-row">
                    <div class="auth-field-group">
                        <label asp-for="Password" class="auth-field-label"></label>
                        <input asp-for="Password" class="auth-field-input" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="auth-field-group">
                        <label asp-for="ConfirmPassword" class="auth-field-label"></label>
                        <input asp-for="ConfirmPassword" class="auth-field-input" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <span asp-validation-summary="All" class="text-danger small"></span>

                <button type="submit" class="btn auth-btn-submit w-100">Registrarse</button>
            </form>

            <p class="auth-switch-text">
                ¿Ya tienes cuenta?
                <a asp-controller="Account" asp-action="Login">Inicia sesión</a>
            </p>
        </div>
    </div>

    <!-- Right: Illustration Side -->
    <div class="auth-illustration-side">
        <img src="~/images/eco-illustration.png" alt="Eco illustration" class="auth-illustration-img" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}